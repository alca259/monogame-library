<?xml version="1.0" encoding="utf-8"?>
<ContentPage x:Class="MonoGame.Editor.Maui.Views.Dialogs.ProjectSettingsDialog"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MonoGame.Editor.Maui.ViewModels.Dialogs"
             x:DataType="vm:ProjectSettingsViewModel"
             BackgroundColor="#80000000"
             Title="Project Settings">

    <Grid>
        <Border BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0"
                WidthRequest="560"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Border BackgroundColor="{StaticResource BgPanel}"
                        StrokeThickness="0"
                        Padding="20,14">
                    <Label Text="Project Settings"
                           Style="{StaticResource PrimaryLabel}"
                           FontSize="15"/>
                </Border>
                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- Tab bar -->
                <Border BackgroundColor="{StaticResource BgPanel}"
                        StrokeThickness="0">
                    <HorizontalStackLayout Spacing="0">
                        <Button Text="General"
                                Style="{StaticResource TabButton}"
                                Command="{Binding SelectTabCommand}"
                                CommandParameter="General"
                                TextColor="#9A9AA2" BackgroundColor="Transparent">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding ActiveTab}" Value="General">
                                    <Setter Property="TextColor" Value="#E6E6E8"/>
                                    <Setter Property="BackgroundColor" Value="#2D2D33"/>
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="Content"
                                Style="{StaticResource TabButton}"
                                Command="{Binding SelectTabCommand}"
                                CommandParameter="Content"
                                TextColor="#9A9AA2" BackgroundColor="Transparent">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding ActiveTab}" Value="Content">
                                    <Setter Property="TextColor" Value="#E6E6E8"/>
                                    <Setter Property="BackgroundColor" Value="#2D2D33"/>
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="Localization"
                                Style="{StaticResource TabButton}"
                                Command="{Binding SelectTabCommand}"
                                CommandParameter="Localization"
                                TextColor="#9A9AA2" BackgroundColor="Transparent">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding ActiveTab}" Value="Localization">
                                    <Setter Property="TextColor" Value="#E6E6E8"/>
                                    <Setter Property="BackgroundColor" Value="#2D2D33"/>
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="Code Gen"
                                Style="{StaticResource TabButton}"
                                Command="{Binding SelectTabCommand}"
                                CommandParameter="CodeGen"
                                TextColor="#9A9AA2" BackgroundColor="Transparent">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding ActiveTab}" Value="CodeGen">
                                    <Setter Property="TextColor" Value="#E6E6E8"/>
                                    <Setter Property="BackgroundColor" Value="#2D2D33"/>
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </HorizontalStackLayout>
                </Border>
                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- ── General tab ── -->
                <ScrollView HeightRequest="320"
                            IsVisible="{Binding ActiveTab, Converter={StaticResource Equals}, ConverterParameter=General}">
                    <Grid Padding="20,16"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                          ColumnDefinitions="140,*"
                          RowSpacing="10"
                          ColumnSpacing="8">

                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Build configuration"
                               Style="{StaticResource DimLabel}"
                               VerticalOptions="Center"/>
                        <Picker Grid.Row="0" Grid.Column="1"
                                ItemsSource="{Binding BuildConfigs}"
                                SelectedItem="{Binding BuildConfiguration}"
                                BackgroundColor="{StaticResource BgPanel}"
                                TextColor="{StaticResource PrimaryLabel}"/>

                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Virtual width"
                               Style="{StaticResource DimLabel}"
                               VerticalOptions="Center"/>
                        <Entry Grid.Row="1" Grid.Column="1"
                               Text="{Binding VirtualWidth}"
                               Keyboard="Numeric"
                               BackgroundColor="{StaticResource BgPanel}"
                               TextColor="{StaticResource PrimaryLabel}"/>

                        <Label Grid.Row="2" Grid.Column="0"
                               Text="Virtual height"
                               Style="{StaticResource DimLabel}"
                               VerticalOptions="Center"/>
                        <Entry Grid.Row="2" Grid.Column="1"
                               Text="{Binding VirtualHeight}"
                               Keyboard="Numeric"
                               BackgroundColor="{StaticResource BgPanel}"
                               TextColor="{StaticResource PrimaryLabel}"/>

                        <Label Grid.Row="3" Grid.Column="0"
                               Text="Game .csproj (rel)"
                               Style="{StaticResource DimLabel}"
                               VerticalOptions="Center"/>
                        <Grid Grid.Row="3" Grid.Column="1"
                              ColumnDefinitions="*,Auto" ColumnSpacing="4">
                            <Entry Grid.Column="0"
                                   Text="{Binding GameAppCsproj}"
                                   BackgroundColor="{StaticResource BgPanel}"
                                   TextColor="{StaticResource PrimaryLabel}"/>
                            <Button Grid.Column="1"
                                    Text="…"
                                    WidthRequest="32"
                                    Style="{StaticResource FlatButton}"
                                    Command="{Binding BrowseCsprojCommand}"/>
                        </Grid>

                        <Label Grid.Row="4" Grid.Column="0"
                               Text="Scripts .csproj (rel)"
                               Style="{StaticResource DimLabel}"
                               VerticalOptions="Center"/>
                        <Grid Grid.Row="4" Grid.Column="1"
                              ColumnDefinitions="*,Auto" ColumnSpacing="4">
                            <Entry Grid.Column="0"
                                   Text="{Binding GameScriptsCsproj}"
                                   BackgroundColor="{StaticResource BgPanel}"
                                   TextColor="{StaticResource PrimaryLabel}"/>
                            <Button Grid.Column="1"
                                    Text="…"
                                    WidthRequest="32"
                                    Style="{StaticResource FlatButton}"
                                    Command="{Binding BrowseScriptsCsprojCommand}"/>
                        </Grid>

                        <Label Grid.Row="5" Grid.Column="0"
                               Text="Grid cell size"
                               Style="{StaticResource DimLabel}"
                               VerticalOptions="Center"/>
                        <Entry Grid.Row="5" Grid.Column="1"
                               Text="{Binding GridCellSize}"
                               Keyboard="Numeric"
                               Placeholder="1"
                               BackgroundColor="{StaticResource BgPanel}"
                               TextColor="{StaticResource PrimaryLabel}"
                               PlaceholderColor="{StaticResource DimLabel}"/>

                    </Grid>
                </ScrollView>

                <!-- ── Content tab ── -->
                <ScrollView HeightRequest="320"
                            IsVisible="{Binding ActiveTab, Converter={StaticResource Equals}, ConverterParameter=Content}">
                    <Grid Padding="20,16"
                          RowDefinitions="Auto,Auto"
                          ColumnDefinitions="140,*"
                          RowSpacing="10"
                          ColumnSpacing="8">

                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Content path (rel)"
                               Style="{StaticResource DimLabel}"
                               VerticalOptions="Center"/>
                        <Entry Grid.Row="0" Grid.Column="1"
                               Text="{Binding ContentRelPath}"
                               BackgroundColor="{StaticResource BgPanel}"
                               TextColor="{StaticResource PrimaryLabel}"/>

                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Localization path (rel)"
                               Style="{StaticResource DimLabel}"
                               VerticalOptions="Center"/>
                        <Grid Grid.Row="1" Grid.Column="1"
                              ColumnDefinitions="*,Auto" ColumnSpacing="4">
                            <Entry Grid.Column="0"
                                   Text="{Binding LocalizationRelPath}"
                                   BackgroundColor="{StaticResource BgPanel}"
                                   TextColor="{StaticResource PrimaryLabel}"/>
                            <Button Grid.Column="1"
                                    Text="…"
                                    WidthRequest="32"
                                    Style="{StaticResource FlatButton}"
                                    Command="{Binding BrowseLocalizationFolderCommand}"/>
                        </Grid>

                    </Grid>
                </ScrollView>

                <!-- ── Localization tab ── -->
                <ScrollView HeightRequest="320"
                            IsVisible="{Binding ActiveTab, Converter={StaticResource Equals}, ConverterParameter=Localization}">
                    <Grid Padding="20,16"
                          RowDefinitions="Auto,Auto"
                          ColumnDefinitions="140,*"
                          RowSpacing="10"
                          ColumnSpacing="8">

                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Default locale"
                               Style="{StaticResource DimLabel}"
                               VerticalOptions="Center"/>
                        <Entry Grid.Row="0" Grid.Column="1"
                               Text="{Binding DefaultLocale}"
                               Placeholder="en-US"
                               BackgroundColor="{StaticResource BgPanel}"
                               TextColor="{StaticResource PrimaryLabel}"
                               PlaceholderColor="{StaticResource DimLabel}"/>

                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Supported locales"
                               Style="{StaticResource DimLabel}"
                               VerticalOptions="Start"
                               Margin="0,6,0,0"/>
                        <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="4">
                            <Entry Text="{Binding SupportedLocales}"
                                   Placeholder="en-US, es-ES, fr-FR (comma-separated)"
                                   BackgroundColor="{StaticResource BgPanel}"
                                   TextColor="{StaticResource PrimaryLabel}"
                                   PlaceholderColor="{StaticResource DimLabel}"/>
                            <Label Text="Comma-separated locale codes."
                                   Style="{StaticResource DimLabel}"
                                   FontSize="10"/>
                        </VerticalStackLayout>

                    </Grid>
                </ScrollView>

                <!-- ── Code Gen tab ── -->
                <ScrollView HeightRequest="320"
                            IsVisible="{Binding ActiveTab, Converter={StaticResource Equals}, ConverterParameter=CodeGen}">
                    <Grid Padding="20,16"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnDefinitions="160,*"
                          RowSpacing="10"
                          ColumnSpacing="8">

                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Root namespace"
                               Style="{StaticResource DimLabel}"
                               VerticalOptions="Center"/>
                        <Entry Grid.Row="0" Grid.Column="1"
                               Text="{Binding RootNamespace}"
                               BackgroundColor="{StaticResource BgPanel}"
                               TextColor="{StaticResource PrimaryLabel}"/>

                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Generated code folder"
                               Style="{StaticResource DimLabel}"
                               VerticalOptions="Center"/>
                        <Entry Grid.Row="1" Grid.Column="1"
                               Text="{Binding GeneratedCodeFolder}"
                               BackgroundColor="{StaticResource BgPanel}"
                               TextColor="{StaticResource PrimaryLabel}"/>

                        <Label Grid.Row="2" Grid.Column="0"
                               Text="Generate on save"
                               Style="{StaticResource DimLabel}"
                               VerticalOptions="Center"/>
                        <CheckBox Grid.Row="2" Grid.Column="1"
                                  IsChecked="{Binding GenerateOnSave}"
                                  Color="{StaticResource AccentBlue}"
                                  HorizontalOptions="Start"/>

                    </Grid>
                </ScrollView>

                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- Footer -->
                <HorizontalStackLayout HorizontalOptions="End"
                                       Spacing="8"
                                       Padding="20,12">
                    <Button Text="Cancel"
                            Style="{StaticResource SmallIconButton}"
                            Command="{Binding CancelCommand}"/>
                    <Button Text="Save"
                            Style="{StaticResource SmallIconButton}"
                            Command="{Binding SubmitCommand}"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
