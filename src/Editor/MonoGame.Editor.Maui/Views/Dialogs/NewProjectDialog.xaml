<?xml version="1.0" encoding="utf-8"?>
<ContentPage x:Class="MonoGame.Editor.Maui.Views.Dialogs.NewProjectDialog"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MonoGame.Editor.Maui.ViewModels.Dialogs"
             x:DataType="vm:NewProjectViewModel"
             BackgroundColor="#80000000"
             Title="New Project">

    <Grid>
        <Border BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0"
                WidthRequest="480"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Border BackgroundColor="{StaticResource BgPanel}"
                        StrokeThickness="0"
                        Padding="20,14">
                    <Label Text="New Project"
                           Style="{StaticResource PrimaryLabel}"
                           FontSize="15"/>
                </Border>
                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- Fields -->
                <Grid Padding="20,16"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                      ColumnDefinitions="120,*"
                      RowSpacing="10"
                      ColumnSpacing="8">

                    <Label Grid.Row="0" Grid.Column="0"
                           Text="Project name"
                           Style="{StaticResource DimLabel}"
                           VerticalOptions="Center"/>
                    <Entry Grid.Row="0" Grid.Column="1"
                           Text="{Binding ProjectName}"
                           Placeholder="MyGame"
                           BackgroundColor="{StaticResource BgPanel}"
                           TextColor="{StaticResource PrimaryLabel}"
                           PlaceholderColor="{StaticResource DimLabel}"/>

                    <Label Grid.Row="1" Grid.Column="0"
                           Text="Parent folder"
                           Style="{StaticResource DimLabel}"
                           VerticalOptions="Center"/>
                    <Grid Grid.Row="1" Grid.Column="1"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="4">
                        <Entry Grid.Column="0"
                               Text="{Binding ParentPath}"
                               Placeholder="C:\Projects"
                               BackgroundColor="{StaticResource BgPanel}"
                               TextColor="{StaticResource PrimaryLabel}"
                               PlaceholderColor="{StaticResource DimLabel}"/>
                        <Button Grid.Column="1"
                                Text="…"
                                Style="{StaticResource SmallIconButton}"
                                WidthRequest="32"
                                Command="{Binding BrowseParentCommand}"/>
                    </Grid>

                    <Label Grid.Row="2" Grid.Column="0"
                           Text="Game .csproj (optional)"
                           Style="{StaticResource DimLabel}"
                           VerticalOptions="Center"/>
                    <Grid Grid.Row="2" Grid.Column="1"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="4">
                        <Entry Grid.Column="0"
                               Text="{Binding GameCsproj}"
                               Placeholder="Relative path to Game.csproj"
                               BackgroundColor="{StaticResource BgPanel}"
                               TextColor="{StaticResource PrimaryLabel}"
                               PlaceholderColor="{StaticResource DimLabel}"/>
                        <Button Grid.Column="1"
                                Text="…"
                                Style="{StaticResource SmallIconButton}"
                                WidthRequest="32"
                                Command="{Binding BrowseCsprojCommand}"/>
                    </Grid>

                </Grid>

                <!-- Validation -->
                <Label Text="{Binding ValidationMessage}"
                       IsVisible="{Binding HasValidationError}"
                       TextColor="#E85050"
                       FontSize="11"
                       Margin="20,0,20,8"/>

                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- Footer -->
                <HorizontalStackLayout HorizontalOptions="End"
                                       Spacing="8"
                                       Padding="20,12">
                    <Button Text="Cancel"
                            Style="{StaticResource LargeIconButton}"
                            Command="{Binding CancelCommand}"/>
                    <Button Text="Create"
                            Style="{StaticResource LargeIconButtonSuccess}"
                            Command="{Binding SubmitCommand}"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
