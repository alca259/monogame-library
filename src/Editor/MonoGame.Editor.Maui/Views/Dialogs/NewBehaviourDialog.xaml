<?xml version="1.0" encoding="utf-8"?>
<ContentPage x:Class="MonoGame.Editor.Maui.Views.Dialogs.NewBehaviourDialog"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="#80000000"
             Title="New Behaviour">

    <Grid>
        <Border BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0"
                WidthRequest="460"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Border BackgroundColor="{StaticResource BgPanel}"
                        StrokeThickness="0"
                        Padding="20,14">
                    <Label Text="New Behaviour"
                           Style="{StaticResource PrimaryLabel}"
                           FontSize="15"/>
                </Border>
                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- Fields -->
                <Grid Padding="20,16"
                      RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="110,*"
                      RowSpacing="10"
                      ColumnSpacing="8">

                    <Label Grid.Row="0" Grid.Column="0"
                           Text="Class name"
                           Style="{StaticResource DimLabel}"
                           VerticalOptions="Center"/>
                    <Entry Grid.Row="0" Grid.Column="1"
                           x:Name="ClassNameEntry"
                           Placeholder="MyBehaviour"
                           BackgroundColor="{StaticResource BgPanel}"
                           TextColor="{StaticResource PrimaryLabel}"
                           PlaceholderColor="{StaticResource DimLabel}"/>

                    <Label Grid.Row="1" Grid.Column="0"
                           Text="Namespace"
                           Style="{StaticResource DimLabel}"
                           VerticalOptions="Center"/>
                    <Grid Grid.Row="1" Grid.Column="1"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="4">
                        <Picker Grid.Column="0"
                                x:Name="NamespacePicker"
                                BackgroundColor="{StaticResource BgPanel}"
                                TextColor="{StaticResource PrimaryLabel}"
                                SelectedIndexChanged="OnNamespacePickerChanged"/>
                        <Entry Grid.Column="1"
                               x:Name="NamespaceCustomEntry"
                               Placeholder="or type…"
                               WidthRequest="130"
                               BackgroundColor="{StaticResource BgPanel}"
                               TextColor="{StaticResource PrimaryLabel}"
                               PlaceholderColor="{StaticResource DimLabel}"/>
                    </Grid>

                    <Label Grid.Row="2" Grid.Column="0"
                           Text="Folder"
                           Style="{StaticResource DimLabel}"
                           VerticalOptions="Center"/>
                    <Entry Grid.Row="2" Grid.Column="1"
                           x:Name="RelativeFolderEntry"
                           Placeholder="Relative to GameScripts root"
                           BackgroundColor="{StaticResource BgPanel}"
                           TextColor="{StaticResource PrimaryLabel}"
                           PlaceholderColor="{StaticResource DimLabel}"/>

                </Grid>

                <!-- Method overrides -->
                <Border BackgroundColor="{StaticResource BgPanel}"
                        StrokeThickness="0"
                        Padding="20,0,20,12">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Override methods"
                               Style="{StaticResource DimLabel}"
                               FontSize="11"/>
                        <HorizontalStackLayout Spacing="16" Wrap="Wrap">
                            <HorizontalStackLayout Spacing="6">
                                <CheckBox x:Name="AwakeCheck" Color="{StaticResource AccentBlue}"/>
                                <Label Text="Awake" Style="{StaticResource DimLabel}" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="6">
                                <CheckBox x:Name="StartCheck" Color="{StaticResource AccentBlue}"/>
                                <Label Text="Start" Style="{StaticResource DimLabel}" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="6">
                                <CheckBox x:Name="UpdateCheck" Color="{StaticResource AccentBlue}" IsChecked="True"/>
                                <Label Text="Update" Style="{StaticResource DimLabel}" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="6">
                                <CheckBox x:Name="DrawCheck" Color="{StaticResource AccentBlue}"/>
                                <Label Text="Draw" Style="{StaticResource DimLabel}" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="6">
                                <CheckBox x:Name="OnDestroyCheck" Color="{StaticResource AccentBlue}"/>
                                <Label Text="OnDestroy" Style="{StaticResource DimLabel}" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Validation -->
                <Label x:Name="ValidationLabel"
                       IsVisible="False"
                       FontSize="11"
                       Margin="20,0,20,8"/>

                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- Footer -->
                <HorizontalStackLayout HorizontalOptions="End"
                                       Spacing="8"
                                       Padding="20,12">
                    <Button Text="Cancel"
                            Style="{StaticResource SmallIconButton}"
                            Clicked="OnCancel"/>
                    <Button Text="Create"
                            Style="{StaticResource SmallIconButton}"
                            Clicked="OnSubmit"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
