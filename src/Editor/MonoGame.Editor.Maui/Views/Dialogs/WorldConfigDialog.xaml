<?xml version="1.0" encoding="utf-8"?>
<ContentPage x:Class="MonoGame.Editor.Maui.Views.Dialogs.WorldConfigDialog"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MonoGame.Editor.Maui.ViewModels.Dialogs"
             x:DataType="vm:WorldConfigViewModel"
             BackgroundColor="#80000000"
             Title="World Configuration">

    <Grid>
        <Border BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0"
                WidthRequest="500"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Border BackgroundColor="{StaticResource BgPanel}"
                        StrokeThickness="0"
                        Padding="20,14">
                    <Label Text="World Configuration"
                           Style="{StaticResource PrimaryLabel}"
                           FontSize="15"/>
                </Border>
                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <ScrollView MaximumHeightRequest="520">
                    <VerticalStackLayout Spacing="0">

                        <!-- Physics 2D section -->
                        <Border BackgroundColor="{StaticResource BgPanel}"
                                StrokeThickness="0"
                                Padding="20,10,20,0">
                            <VerticalStackLayout Spacing="8">
                                <HorizontalStackLayout Spacing="8">
                                    <CheckBox IsChecked="{Binding UsePhysics2D}"
                                              Color="{StaticResource AccentBlue}"/>
                                    <Label Text="Physics 2D"
                                           Style="{StaticResource PrimaryLabel}"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Grid RowDefinitions="Auto"
                                      ColumnDefinitions="100,80,100,80"
                                      ColumnSpacing="8"
                                      IsVisible="{Binding UsePhysics2D}"
                                      Margin="28,0,0,0">
                                    <Label Grid.Column="0"
                                           Text="Gravity X"
                                           Style="{StaticResource DimLabel}"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Column="1"
                                           Text="{Binding GravityX}"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                    <Label Grid.Column="2"
                                           Text="Gravity Y"
                                           Style="{StaticResource DimLabel}"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Column="3"
                                           Text="{Binding GravityY}"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                        <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" Margin="0,10,0,0"/>

                        <!-- Lighting section -->
                        <Border BackgroundColor="{StaticResource BgPanel}"
                                StrokeThickness="0"
                                Padding="20,10,20,0">
                            <VerticalStackLayout Spacing="8">
                                <HorizontalStackLayout Spacing="8">
                                    <CheckBox IsChecked="{Binding UseLighting}"
                                              Color="{StaticResource AccentBlue}"/>
                                    <Label Text="Lighting"
                                           Style="{StaticResource PrimaryLabel}"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Grid RowDefinitions="Auto"
                                      ColumnDefinitions="80,56,56,56,56"
                                      ColumnSpacing="6"
                                      IsVisible="{Binding UseLighting}"
                                      Margin="28,0,0,0">
                                    <Label Grid.Column="0"
                                           Text="Ambient RGBA"
                                           Style="{StaticResource DimLabel}"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Column="1"
                                           Text="{Binding AmbientR}"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                    <Entry Grid.Column="2"
                                           Text="{Binding AmbientG}"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                    <Entry Grid.Column="3"
                                           Text="{Binding AmbientB}"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                    <Entry Grid.Column="4"
                                           Text="{Binding AmbientA}"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                        <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" Margin="0,10,0,0"/>

                        <!-- Navigation section -->
                        <Border BackgroundColor="{StaticResource BgPanel}"
                                StrokeThickness="0"
                                Padding="20,10,20,0">
                            <VerticalStackLayout Spacing="8">
                                <HorizontalStackLayout Spacing="8">
                                    <CheckBox IsChecked="{Binding UseNavigation}"
                                              Color="{StaticResource AccentBlue}"/>
                                    <Label Text="Navigation (NavMesh)"
                                           Style="{StaticResource PrimaryLabel}"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Grid RowDefinitions="Auto,Auto,Auto"
                                      ColumnDefinitions="90,80,90,80"
                                      ColumnSpacing="8"
                                      RowSpacing="6"
                                      IsVisible="{Binding UseNavigation}"
                                      Margin="28,0,0,0">
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="Grid width"
                                           Style="{StaticResource DimLabel}"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Row="0" Grid.Column="1"
                                           Text="{Binding NavWidth}"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                    <Label Grid.Row="0" Grid.Column="2"
                                           Text="Grid height"
                                           Style="{StaticResource DimLabel}"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Row="0" Grid.Column="3"
                                           Text="{Binding NavHeight}"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                    <Label Grid.Row="1" Grid.Column="0"
                                           Text="Cell size"
                                           Style="{StaticResource DimLabel}"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Row="1" Grid.Column="1"
                                           Text="{Binding NavCellSize}"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                    <Label Grid.Row="2" Grid.Column="0"
                                           Text="Origin X"
                                           Style="{StaticResource DimLabel}"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Row="2" Grid.Column="1"
                                           Text="{Binding NavOriginX}"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                    <Label Grid.Row="2" Grid.Column="2"
                                           Text="Origin Y"
                                           Style="{StaticResource DimLabel}"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Row="2" Grid.Column="3"
                                           Text="{Binding NavOriginY}"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                        <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" Margin="0,10,0,0"/>

                        <!-- Audio section -->
                        <Border BackgroundColor="{StaticResource BgPanel}"
                                StrokeThickness="0"
                                Padding="20,10,20,10">
                            <HorizontalStackLayout Spacing="8">
                                <CheckBox IsChecked="{Binding UseAudio}"
                                          Color="{StaticResource AccentBlue}"/>
                                <Label Text="Audio"
                                       Style="{StaticResource PrimaryLabel}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </ScrollView>

                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- Footer -->
                <HorizontalStackLayout HorizontalOptions="End"
                                       Spacing="8"
                                       Padding="20,12">
                    <Button Text="Cancel"
                            Style="{StaticResource SmallIconButton}"
                            Command="{Binding CancelCommand}"/>
                    <Button Text="Apply"
                            Style="{StaticResource SmallIconButton}"
                            Command="{Binding SubmitCommand}"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
