<?xml version="1.0" encoding="utf-8"?>
<ContentPage x:Class="MonoGame.Editor.Maui.Views.Dialogs.WorldConfigDialog"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="#80000000"
             Title="World Configuration">

    <Grid>
        <Border BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0"
                WidthRequest="500"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Border BackgroundColor="{StaticResource BgPanel}"
                        StrokeThickness="0"
                        Padding="20,14">
                    <Label Text="World Configuration"
                           Style="{StaticResource PrimaryLabel}"
                           FontSize="15"/>
                </Border>
                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <ScrollView MaximumHeightRequest="520">
                    <VerticalStackLayout Spacing="0">

                        <!-- Physics 2D section -->
                        <Border BackgroundColor="{StaticResource BgPanel}"
                                StrokeThickness="0"
                                Padding="20,10,20,0">
                            <VerticalStackLayout Spacing="8">
                                <HorizontalStackLayout Spacing="8">
                                    <CheckBox x:Name="Physics2DCheck"
                                              Color="{StaticResource AccentBlue}"
                                              CheckedChanged="OnPhysics2DToggled"/>
                                    <Label Text="Physics 2D"
                                           Style="{StaticResource PrimaryLabel}"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Grid x:Name="PhysicsFields"
                                      RowDefinitions="Auto"
                                      ColumnDefinitions="100,80,100,80"
                                      ColumnSpacing="8"
                                      IsVisible="False"
                                      Margin="28,0,0,0">
                                    <Label Grid.Column="0"
                                           Text="Gravity X"
                                           Style="{StaticResource DimLabel}"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Column="1"
                                           x:Name="GravityXEntry"
                                           Text="0"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                    <Label Grid.Column="2"
                                           Text="Gravity Y"
                                           Style="{StaticResource DimLabel}"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Column="3"
                                           x:Name="GravityYEntry"
                                           Text="-9.8"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                        <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" Margin="0,10,0,0"/>

                        <!-- Lighting section -->
                        <Border BackgroundColor="{StaticResource BgPanel}"
                                StrokeThickness="0"
                                Padding="20,10,20,0">
                            <VerticalStackLayout Spacing="8">
                                <HorizontalStackLayout Spacing="8">
                                    <CheckBox x:Name="LightingCheck"
                                              Color="{StaticResource AccentBlue}"
                                              CheckedChanged="OnLightingToggled"/>
                                    <Label Text="Lighting"
                                           Style="{StaticResource PrimaryLabel}"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Grid x:Name="LightingFields"
                                      RowDefinitions="Auto"
                                      ColumnDefinitions="80,56,56,56,56"
                                      ColumnSpacing="6"
                                      IsVisible="False"
                                      Margin="28,0,0,0">
                                    <Label Grid.Column="0"
                                           Text="Ambient RGBA"
                                           Style="{StaticResource DimLabel}"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Column="1"
                                           x:Name="AmbientREntry"
                                           Text="255"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                    <Entry Grid.Column="2"
                                           x:Name="AmbientGEntry"
                                           Text="255"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                    <Entry Grid.Column="3"
                                           x:Name="AmbientBEntry"
                                           Text="255"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                    <Entry Grid.Column="4"
                                           x:Name="AmbientAEntry"
                                           Text="255"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                        <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" Margin="0,10,0,0"/>

                        <!-- Navigation section -->
                        <Border BackgroundColor="{StaticResource BgPanel}"
                                StrokeThickness="0"
                                Padding="20,10,20,0">
                            <VerticalStackLayout Spacing="8">
                                <HorizontalStackLayout Spacing="8">
                                    <CheckBox x:Name="NavigationCheck"
                                              Color="{StaticResource AccentBlue}"
                                              CheckedChanged="OnNavigationToggled"/>
                                    <Label Text="Navigation (NavMesh)"
                                           Style="{StaticResource PrimaryLabel}"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Grid x:Name="NavigationFields"
                                      RowDefinitions="Auto,Auto,Auto"
                                      ColumnDefinitions="90,80,90,80"
                                      ColumnSpacing="8"
                                      RowSpacing="6"
                                      IsVisible="False"
                                      Margin="28,0,0,0">
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="Grid width"
                                           Style="{StaticResource DimLabel}"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Row="0" Grid.Column="1"
                                           x:Name="NavWidthEntry"
                                           Text="64"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                    <Label Grid.Row="0" Grid.Column="2"
                                           Text="Grid height"
                                           Style="{StaticResource DimLabel}"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Row="0" Grid.Column="3"
                                           x:Name="NavHeightEntry"
                                           Text="64"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                    <Label Grid.Row="1" Grid.Column="0"
                                           Text="Cell size"
                                           Style="{StaticResource DimLabel}"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Row="1" Grid.Column="1"
                                           x:Name="NavCellSizeEntry"
                                           Text="32"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                    <Label Grid.Row="2" Grid.Column="0"
                                           Text="Origin X"
                                           Style="{StaticResource DimLabel}"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Row="2" Grid.Column="1"
                                           x:Name="NavOriginXEntry"
                                           Text="0"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                    <Label Grid.Row="2" Grid.Column="2"
                                           Text="Origin Y"
                                           Style="{StaticResource DimLabel}"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Row="2" Grid.Column="3"
                                           x:Name="NavOriginYEntry"
                                           Text="0"
                                           Keyboard="Numeric"
                                           BackgroundColor="{StaticResource BgChrome}"
                                           TextColor="{StaticResource PrimaryLabel}"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                        <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" Margin="0,10,0,0"/>

                        <!-- Audio section -->
                        <Border BackgroundColor="{StaticResource BgPanel}"
                                StrokeThickness="0"
                                Padding="20,10,20,10">
                            <HorizontalStackLayout Spacing="8">
                                <CheckBox x:Name="AudioCheck"
                                          Color="{StaticResource AccentBlue}"/>
                                <Label Text="Audio"
                                       Style="{StaticResource PrimaryLabel}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </ScrollView>

                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- Footer -->
                <HorizontalStackLayout HorizontalOptions="End"
                                       Spacing="8"
                                       Padding="20,12">
                    <Button Text="Cancel"
                            Style="{StaticResource SmallIconButton}"
                            Clicked="OnCancel"/>
                    <Button Text="Apply"
                            Style="{StaticResource SmallIconButton}"
                            Clicked="OnSubmit"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
