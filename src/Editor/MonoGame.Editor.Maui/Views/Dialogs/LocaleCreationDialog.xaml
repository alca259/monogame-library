<?xml version="1.0" encoding="utf-8"?>
<ContentPage x:Class="MonoGame.Editor.Maui.Views.Dialogs.LocaleCreationDialog"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="#80000000"
             Title="Add Locale">

    <Grid>
        <Border BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0"
                WidthRequest="380"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Border BackgroundColor="{StaticResource BgPanel}"
                        StrokeThickness="0"
                        Padding="20,14">
                    <Label Text="Add Locale"
                           Style="{StaticResource PrimaryLabel}"
                           FontSize="15"/>
                </Border>
                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- Fields -->
                <Grid Padding="20,16"
                      RowDefinitions="Auto,Auto"
                      ColumnDefinitions="80,*"
                      RowSpacing="10"
                      ColumnSpacing="8">

                    <Label Grid.Row="0" Grid.Column="0"
                           Text="Code"
                           Style="{StaticResource DimLabel}"
                           VerticalOptions="Center"/>
                    <Entry Grid.Row="0" Grid.Column="1"
                           x:Name="LocaleCodeEntry"
                           Placeholder="en-US"
                           BackgroundColor="{StaticResource BgPanel}"
                           TextColor="{StaticResource PrimaryLabel}"
                           PlaceholderColor="{StaticResource DimLabel}"/>

                    <Label Grid.Row="1" Grid.Column="0"
                           Text="Display name"
                           Style="{StaticResource DimLabel}"
                           VerticalOptions="Center"/>
                    <Entry Grid.Row="1" Grid.Column="1"
                           x:Name="DisplayNameEntry"
                           Placeholder="English (US)"
                           BackgroundColor="{StaticResource BgPanel}"
                           TextColor="{StaticResource PrimaryLabel}"
                           PlaceholderColor="{StaticResource DimLabel}"/>

                </Grid>

                <!-- Validation -->
                <Label x:Name="ValidationLabel"
                       IsVisible="False"
                       FontSize="11"
                       Margin="20,0,20,8"/>

                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- Footer -->
                <HorizontalStackLayout HorizontalOptions="End"
                                       Spacing="8"
                                       Padding="20,12">
                    <Button Text="Cancel"
                            Style="{StaticResource SmallIconButton}"
                            Clicked="OnCancel"/>
                    <Button Text="Add"
                            Style="{StaticResource SmallIconButton}"
                            Clicked="OnSubmit"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
