<?xml version="1.0" encoding="utf-8"?>
<ContentPage x:Class="MonoGame.Editor.Maui.Views.Dialogs.NewSceneDialog"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MonoGame.Editor.Maui.ViewModels.Dialogs"
             x:DataType="vm:NewSceneViewModel"
             BackgroundColor="#80000000"
             Title="New Scene">

    <Grid>
        <Border BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0"
                WidthRequest="400"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Border BackgroundColor="{StaticResource BgPanel}"
                        StrokeThickness="0"
                        Padding="20,14">
                    <Label Text="New Scene"
                           Style="{StaticResource PrimaryLabel}"
                           FontSize="15"/>
                </Border>
                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- Fields -->
                <Grid Padding="20,16"
                      RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="100,*"
                      RowSpacing="10"
                      ColumnSpacing="8">

                    <Label Grid.Row="0" Grid.Column="0"
                           Text="Scene name"
                           Style="{StaticResource DimLabel}"
                           VerticalOptions="Center"/>
                    <Entry Grid.Row="0" Grid.Column="1"
                           Text="{Binding SceneName}"
                           Placeholder="MainScene"
                           BackgroundColor="{StaticResource BgPanel}"
                           TextColor="{StaticResource PrimaryLabel}"
                           PlaceholderColor="{StaticResource DimLabel}"/>

                    <Label Grid.Row="1" Grid.Column="0"
                           Text="World width"
                           Style="{StaticResource DimLabel}"
                           VerticalOptions="Center"/>
                    <Entry Grid.Row="1" Grid.Column="1"
                           Text="{Binding WorldWidth}"
                           Keyboard="Numeric"
                           BackgroundColor="{StaticResource BgPanel}"
                           TextColor="{StaticResource PrimaryLabel}"/>

                    <Label Grid.Row="2" Grid.Column="0"
                           Text="World height"
                           Style="{StaticResource DimLabel}"
                           VerticalOptions="Center"/>
                    <Entry Grid.Row="2" Grid.Column="1"
                           Text="{Binding WorldHeight}"
                           Keyboard="Numeric"
                           BackgroundColor="{StaticResource BgPanel}"
                           TextColor="{StaticResource PrimaryLabel}"/>

                </Grid>

                <!-- Validation -->
                <Label Text="{Binding ValidationMessage}"
                       IsVisible="{Binding HasValidationError}"
                       TextColor="#E85050"
                       FontSize="11"
                       Margin="20,0,20,8"/>

                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- Footer -->
                <HorizontalStackLayout HorizontalOptions="End"
                                       Spacing="8"
                                       Padding="20,12">
                    <Button Text="Cancel"
                            Style="{StaticResource SmallIconButton}"
                            Command="{Binding CancelCommand}"/>
                    <Button Text="Create"
                            Style="{StaticResource SmallIconButton}"
                            Command="{Binding SubmitCommand}"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
