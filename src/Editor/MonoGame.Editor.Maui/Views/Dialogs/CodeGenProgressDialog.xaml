<?xml version="1.0" encoding="utf-8"?>
<ContentPage x:Class="MonoGame.Editor.Maui.Views.Dialogs.CodeGenProgressDialog"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="#80000000"
             Title="Code Generation">

    <Grid>
        <Border BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0"
                WidthRequest="520"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Border BackgroundColor="{StaticResource BgPanel}"
                        StrokeThickness="0"
                        Padding="20,14">
                    <Label Text="Code Generation"
                           Style="{StaticResource PrimaryLabel}"
                           FontSize="15"/>
                </Border>
                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- File list -->
                <ScrollView HeightRequest="280">
                    <VerticalStackLayout x:Name="FileListStack"
                                         Spacing="0"
                                         Padding="12,8"/>
                </ScrollView>
                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- Summary -->
                <Border BackgroundColor="{StaticResource BgPanel}"
                        StrokeThickness="0"
                        Padding="20,10">
                    <Label x:Name="SummaryLabel"
                           Text="Running…"
                           Style="{StaticResource DimLabel}"
                           FontSize="12"/>
                </Border>

                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- Footer -->
                <HorizontalStackLayout HorizontalOptions="End"
                                       Spacing="8"
                                       Padding="20,12">
                    <Button x:Name="CloseButton"
                            Text="Close"
                            Style="{StaticResource SmallIconButton}"
                            IsEnabled="False"
                            Clicked="OnClose"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
