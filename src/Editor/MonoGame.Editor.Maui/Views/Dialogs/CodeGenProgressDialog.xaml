<?xml version="1.0" encoding="utf-8"?>
<ContentPage x:Class="MonoGame.Editor.Maui.Views.Dialogs.CodeGenProgressDialog"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MonoGame.Editor.Maui.ViewModels.Dialogs"
             x:DataType="vm:CodeGenProgressViewModel"
             BackgroundColor="#80000000"
             Title="Code Generation">

    <Grid>
        <Border BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0"
                WidthRequest="520"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Border BackgroundColor="{StaticResource BgPanel}"
                        StrokeThickness="0"
                        Padding="20,14">
                    <Label Text="Code Generation"
                           Style="{StaticResource PrimaryLabel}"
                           FontSize="15"/>
                </Border>
                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- File list -->
                <ScrollView HeightRequest="280">
                    <VerticalStackLayout Spacing="0"
                                         Padding="12,8"
                                         BindableLayout.ItemsSource="{Binding Files}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:CodeGenFileItem">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Padding="4,3">
                                    <Label Grid.Column="0"
                                           Text="{Binding Icon}"
                                           TextColor="{Binding Color}"
                                           FontSize="12"
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding Text}"
                                           TextColor="{Binding Color}"
                                           FontSize="12"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </ScrollView>
                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- Summary -->
                <Border BackgroundColor="{StaticResource BgPanel}"
                        StrokeThickness="0"
                        Padding="20,10">
                    <Label Text="{Binding SummaryText}"
                           TextColor="{Binding SummaryColor}"
                           Style="{StaticResource DimLabel}"
                           FontSize="12"/>
                </Border>

                <BoxView Color="{StaticResource BorderColor}" HeightRequest="1"/>

                <!-- Footer -->
                <HorizontalStackLayout HorizontalOptions="End"
                                       Spacing="8"
                                       Padding="20,12">
                    <Button Text="Close"
                            Style="{StaticResource SmallIconButton}"
                            IsEnabled="{Binding CanClose}"
                            Command="{Binding CloseCommand}"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
