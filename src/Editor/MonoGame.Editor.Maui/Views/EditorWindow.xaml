<?xml version="1.0" encoding="utf-8"?>
<ContentPage x:Class="MonoGame.Editor.Maui.Views.EditorWindow"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:panels="clr-namespace:MonoGame.Editor.Maui.Views.Panels"
             xmlns:vm="clr-namespace:MonoGame.Editor.Maui.ViewModels"
             x:DataType="vm:EditorWindowViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource BgWindow}"
             Padding="0">

    <!--
        Layout de 5 zonas:
          Row 0 — MenuBar   (28px)
          Row 1 — Toolbar   (42px)
          Row 2 — Body      (*)
          Row 3 — Dock      (266px)
          Row 4 — StatusBar (24px)
    -->
    <Grid x:Name="MainGrid"
          RowDefinitions="28,42,*,266,24"
          RowSpacing="0">

        <!-- ── Row 0: Menu bar ──────────────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0">
            <HorizontalStackLayout Spacing="0"
                                   VerticalOptions="Fill"
                                   Padding="4,0">
                <Button x:Name="FileMenuBtn"    Text="File"    Style="{StaticResource MenuButton}" Clicked="OnFileMenuClicked"/>
                <Button x:Name="EditMenuBtn"    Text="Edit"    Style="{StaticResource MenuButton}" Clicked="OnEditMenuClicked"/>
                <Button x:Name="ProjectMenuBtn" Text="Project" Style="{StaticResource MenuButton}" Clicked="OnProjectMenuClicked"/>
                <Button x:Name="DebugMenuBtn"   Text="Debug"   Style="{StaticResource MenuButton}" Clicked="OnDebugMenuClicked"/>
                <Button x:Name="ViewMenuBtn"    Text="View"    Style="{StaticResource MenuButton}" Clicked="OnViewMenuClicked"/>
            </HorizontalStackLayout>
        </Border>
        <!-- MenuBar bottom separator -->
        <BoxView Grid.Row="0" VerticalOptions="End"
                 HeightRequest="1" Color="{StaticResource BorderColor}"/>

        <!-- ── Row 1: Toolbar ───────────────────────────────────── -->
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0">
            <HorizontalStackLayout Spacing="2"
                                   VerticalOptions="Center"
                                   Padding="8,0">

                <!-- Gizmo tools -->
                <Button Text="↖" ToolTipProperties.Text="Select (Q)"
                        Style="{StaticResource ToolButton}"
                        Command="{Binding ActivateToolCommand}" CommandParameter="Select"
                        IsEnabled="{Binding ToolsEnabled}"
                        BackgroundColor="Transparent" TextColor="#9A9AA2">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding ActiveTool}" Value="Select">
                            <Setter Property="BackgroundColor" Value="#4A9EFF"/>
                            <Setter Property="TextColor" Value="#FFFFFF"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="✥" ToolTipProperties.Text="Move (W)"
                        Style="{StaticResource ToolButton}"
                        Command="{Binding ActivateToolCommand}" CommandParameter="Move"
                        IsEnabled="{Binding ToolsEnabled}"
                        BackgroundColor="Transparent" TextColor="#9A9AA2">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding ActiveTool}" Value="Move">
                            <Setter Property="BackgroundColor" Value="#4A9EFF"/>
                            <Setter Property="TextColor" Value="#FFFFFF"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="↺" ToolTipProperties.Text="Rotate (E)"
                        Style="{StaticResource ToolButton}"
                        Command="{Binding ActivateToolCommand}" CommandParameter="Rotate"
                        IsEnabled="{Binding ToolsEnabled}"
                        BackgroundColor="Transparent" TextColor="#9A9AA2">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding ActiveTool}" Value="Rotate">
                            <Setter Property="BackgroundColor" Value="#4A9EFF"/>
                            <Setter Property="TextColor" Value="#FFFFFF"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="⤡" ToolTipProperties.Text="Scale (R)"
                        Style="{StaticResource ToolButton}"
                        Command="{Binding ActivateToolCommand}" CommandParameter="Scale"
                        IsEnabled="{Binding ToolsEnabled}"
                        BackgroundColor="Transparent" TextColor="#9A9AA2">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding ActiveTool}" Value="Scale">
                            <Setter Property="BackgroundColor" Value="#4A9EFF"/>
                            <Setter Property="TextColor" Value="#FFFFFF"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="▭" ToolTipProperties.Text="Rect Transform (T)"
                        Style="{StaticResource ToolButton}"
                        Command="{Binding ActivateToolCommand}" CommandParameter="Rect"
                        IsEnabled="{Binding ToolsEnabled}"
                        BackgroundColor="Transparent" TextColor="#9A9AA2">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding ActiveTool}" Value="Rect">
                            <Setter Property="BackgroundColor" Value="#4A9EFF"/>
                            <Setter Property="TextColor" Value="#FFFFFF"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="✋" ToolTipProperties.Text="Pan (H)"
                        Style="{StaticResource ToolButton}"
                        Command="{Binding ActivateToolCommand}" CommandParameter="Pan"
                        IsEnabled="{Binding ToolsEnabled}"
                        BackgroundColor="Transparent" TextColor="#9A9AA2">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding ActiveTool}" Value="Pan">
                            <Setter Property="BackgroundColor" Value="#4A9EFF"/>
                            <Setter Property="TextColor" Value="#FFFFFF"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Separator -->
                <BoxView WidthRequest="1" HeightRequest="24"
                         Color="{StaticResource BorderColor}"
                         Margin="6,0" VerticalOptions="Center"/>

                <!-- Mode toggles -->
                <Button Text="SNAP" ToolTipProperties.Text="Snap to Grid (G)"
                        Style="{StaticResource PillButton}"
                        Command="{Binding ToggleSnapCommand}"
                        IsEnabled="{Binding ToolsEnabled}"
                        BackgroundColor="#252528" TextColor="#9A9AA2" BorderColor="#34343A">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsSnap}" Value="True">
                            <Setter Property="BackgroundColor" Value="#4A9EFF"/>
                            <Setter Property="TextColor" Value="#FFFFFF"/>
                            <Setter Property="BorderColor" Value="#4A9EFF"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="NAV" ToolTipProperties.Text="Navigate Mode"
                        Style="{StaticResource PillButton}"
                        Command="{Binding ToggleNavCommand}"
                        IsEnabled="{Binding ToolsEnabled}"
                        BackgroundColor="#252528" TextColor="#9A9AA2" BorderColor="#34343A">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsNav}" Value="True">
                            <Setter Property="BackgroundColor" Value="#4A9EFF"/>
                            <Setter Property="TextColor" Value="#FFFFFF"/>
                            <Setter Property="BorderColor" Value="#4A9EFF"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="RES" ToolTipProperties.Text="Resolution Mode"
                        Style="{StaticResource PillButton}"
                        Command="{Binding ToggleResCommand}"
                        IsEnabled="{Binding ToolsEnabled}"
                        BackgroundColor="#252528" TextColor="#9A9AA2" BorderColor="#34343A">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsRes}" Value="True">
                            <Setter Property="BackgroundColor" Value="#4A9EFF"/>
                            <Setter Property="TextColor" Value="#FFFFFF"/>
                            <Setter Property="BorderColor" Value="#4A9EFF"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Separator -->
                <BoxView WidthRequest="1" HeightRequest="24"
                         Color="{StaticResource BorderColor}"
                         Margin="6,0" VerticalOptions="Center"/>

                <!-- Transport -->
                <Button Text="{Binding PlayButtonText}"
                        ToolTipProperties.Text="Play (F5)"
                        Style="{StaticResource PlayButton}"
                        Command="{Binding PlayCommand}"
                        IsEnabled="{Binding CanPlay}"/>
                <Button Text="■"
                        ToolTipProperties.Text="Stop (Shift+F5)"
                        Style="{StaticResource StopButton}"
                        Command="{Binding StopCommand}"
                        IsEnabled="{Binding CanStop}"
                        BackgroundColor="{Binding StopBackground}"
                        TextColor="{Binding StopForeground}"/>

            </HorizontalStackLayout>
        </Border>
        <!-- Toolbar bottom separator -->
        <BoxView Grid.Row="1" VerticalOptions="End"
                 HeightRequest="1" Color="{StaticResource BorderColor}"/>

        <!-- ── Row 2: Center body ────────────────────────────────── -->
        <Grid x:Name="BodyGrid"
              Grid.Row="2"
              ColumnDefinitions="268,4,*,4,362"
              ColumnSpacing="0">

            <panels:SceneHierarchyView Grid.Column="0"/>

            <BoxView x:Name="HierarchySep" Grid.Column="1" Color="{StaticResource BorderColor}"/>

            <GraphicsView x:Name="Viewport"
                          Grid.Column="2"
                          BackgroundColor="{StaticResource BgWindow}">
                <GraphicsView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnViewportTapped"/>
                    <PanGestureRecognizer PanUpdated="OnViewportPanned"/>
                    <PinchGestureRecognizer PinchUpdated="OnViewportPinched"/>
                    <PointerGestureRecognizer PointerMoved="OnViewportPointerMoved"
                                              PointerEntered="OnViewportPointerEntered"
                                              PointerExited="OnViewportPointerExited"/>
                </GraphicsView.GestureRecognizers>
            </GraphicsView>

            <!-- Resaltado del viewport activo (overlay, sin afectar al layout) -->
            <Border Grid.Column="2"
                    InputTransparent="True" BackgroundColor="Transparent" StrokeThickness="1"
                    Stroke="{Binding IsViewportFocused, Converter={StaticResource BoolToColor}, ConverterParameter='#4A9EFF|#00000000'}"/>

            <BoxView x:Name="InspectorSep" Grid.Column="3" Color="{StaticResource BorderColor}"/>

            <panels:InspectorView Grid.Column="4"/>
        </Grid>

        <!-- ── Row 3: Dock bar ───────────────────────────────────── -->
        <Grid x:Name="DockRow" Grid.Row="3" RowDefinitions="4,*" RowSpacing="0">
            <BoxView x:Name="DockSep" Grid.Row="0" Color="{StaticResource BorderColor}"/>
            <panels:DockBarView Grid.Row="1"/>
        </Grid>

        <!-- ── Row 4: Status bar ─────────────────────────────────── -->
        <Border Grid.Row="4"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0">
            <Grid ColumnDefinitions="Auto,1,*,Auto,Auto"
                  ColumnSpacing="0">

                <!-- Build status segment -->
                <Border Grid.Column="0"
                        BackgroundColor="{Binding BuildStatusBackground}"
                        StrokeThickness="0"
                        Padding="8,0">
                    <Label Text="{Binding BuildStatusText}"
                           TextColor="{Binding BuildStatusColor}"
                           Style="{StaticResource DimLabel}"
                           VerticalOptions="Center"/>
                </Border>

                <!-- Separator -->
                <BoxView Grid.Column="1" Color="{StaticResource BorderColor}" VerticalOptions="Fill"/>

                <!-- Scene object count -->
                <Label Grid.Column="2"
                       Text="{Binding ObjectCountText}"
                       Style="{StaticResource DimLabel}"
                       Margin="8,0"
                       VerticalOptions="Center"/>

                <!-- Platform info -->
                <Label Grid.Column="3"
                       Text="x64 · Debug"
                       Style="{StaticResource DimLabel}"
                       Margin="8,0"
                       VerticalOptions="Center"/>

                <!-- FPS counter -->
                <Label Grid.Column="4"
                       Text="{Binding FpsText}"
                       Style="{StaticResource MonoLabel}"
                       Margin="8,0"
                       VerticalOptions="Center"/>
            </Grid>
        </Border>
        <!-- StatusBar top separator -->
        <BoxView Grid.Row="4" VerticalOptions="Start"
                 HeightRequest="1" Color="{StaticResource BorderColor}"/>

        <!-- ── Dropdown menu overlay ─────────────────────────────────── -->
        <Grid x:Name="MenuOverlay"
              Grid.RowSpan="5"
              IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnMenuOverlayTapped"/>
            </Grid.GestureRecognizers>

            <Border x:Name="DropdownPanel"
                    BackgroundColor="{StaticResource BgChrome}"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1"
                    HorizontalOptions="Start"
                    VerticalOptions="Start"
                    Margin="4,28,0,0"
                    MinimumWidthRequest="200">
                <VerticalStackLayout x:Name="DropdownStack" Spacing="0"/>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
