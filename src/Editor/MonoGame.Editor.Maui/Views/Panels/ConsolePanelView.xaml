<?xml version="1.0" encoding="utf-8"?>
<ContentView x:Class="MonoGame.Editor.Maui.Views.Panels.ConsolePanelView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MonoGame.Editor.Maui.Controls"
             xmlns:vm="clr-namespace:MonoGame.Editor.Maui.ViewModels.Panels"
             x:DataType="vm:ConsolePanelViewModel"
             BackgroundColor="{StaticResource BgPanel}">

    <Grid RowDefinitions="28,1,*" RowSpacing="0">

        <!-- ── Toolbar ──────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0">
            <Grid ColumnDefinitions="Auto,Auto,Auto,1,Auto,*" ColumnSpacing="2" Padding="4,2">

                <Button Grid.Column="0"
                        Text="ℹ"
                        ToolTipProperties.Text="Toggle Info"
                        Style="{StaticResource SmallIconButton}"
                        TextColor="{Binding ShowInfo, Converter={StaticResource BoolToColor}, ConverterParameter='#E6E6E8|#6A6A72'}"
                        Command="{Binding ToggleInfoCommand}"/>
                <Button Grid.Column="1"
                        Text="⚠"
                        ToolTipProperties.Text="Toggle Warnings"
                        Style="{StaticResource SmallIconButton}"
                        TextColor="{Binding ShowWarn, Converter={StaticResource BoolToColor}, ConverterParameter='#E6E6E8|#6A6A72'}"
                        Command="{Binding ToggleWarnCommand}"/>
                <Button Grid.Column="2"
                        Text="✕"
                        ToolTipProperties.Text="Toggle Errors"
                        Style="{StaticResource SmallIconButton}"
                        TextColor="{Binding ShowError, Converter={StaticResource BoolToColor}, ConverterParameter='#E6E6E8|#6A6A72'}"
                        Command="{Binding ToggleErrorCommand}"/>

                <BoxView Grid.Column="3"
                         Color="{StaticResource BorderColor}"
                         VerticalOptions="Fill"
                         Margin="2,2"/>

                <Button Grid.Column="4"
                        Text="📋"
                        ToolTipProperties.Text="Copy all visible log lines"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding CopyAllCommand}"/>

                <Button Grid.Column="5"
                        Text="Clear"
                        Style="{StaticResource SmallIconButton}"
                        HorizontalOptions="End"
                        Command="{Binding ClearCommand}"/>
            </Grid>
        </Border>
        <BoxView Grid.Row="1" Color="{StaticResource BorderColor}"/>

        <!-- ── Log entries ───────────────────────────────────────── -->
        <CollectionView Grid.Row="2"
                        x:Name="LogList"
                        ItemsSource="{Binding VisibleEntries}"
                        SelectionMode="None"
                        BackgroundColor="{StaticResource BgPanel}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Label Text="{Binding .}"
                           Style="{StaticResource MonoLabel}"
                           Padding="8,2"
                           FontSize="11"
                           LineBreakMode="WordWrap">
                        <Label.Behaviors>
                            <controls:TextSelectableBehavior />
                        </Label.Behaviors>
                    </Label>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="No log entries"
                       Style="{StaticResource PlaceholderLabel}"
                       Margin="0,24"/>
            </CollectionView.EmptyView>
        </CollectionView>

    </Grid>
</ContentView>
