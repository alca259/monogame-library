<?xml version="1.0" encoding="utf-8"?>
<ContentView x:Class="MonoGame.Editor.Maui.Views.Panels.ScriptBrowserView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MonoGame.Editor.Maui.Views.Panels"
             xmlns:vm="clr-namespace:MonoGame.Editor.Maui.ViewModels.Panels"
             x:DataType="vm:ScriptBrowserViewModel"
             BackgroundColor="{StaticResource BgPanel}">

    <Grid RowDefinitions="28,1,*" RowSpacing="0">

        <!-- ── Toolbar ──────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,1,Auto,Auto,1,*" ColumnSpacing="4" Padding="4,2">
                <Button Grid.Column="0"
                        Text="⟳ Rescan"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding RescanCommand}"/>
                <Button Grid.Column="1"
                        Text="📁"
                        ToolTipProperties.Text="New folder"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding NewFolderCommand}"/>
                <Button Grid.Column="2"
                        Text="✎"
                        ToolTipProperties.Text="Rename folder"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding FolderRenameCommand}"/>
                <Button Grid.Column="3"
                        Text="🗑"
                        ToolTipProperties.Text="Delete folder"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding FolderDeleteCommand}"/>
                <BoxView Grid.Column="4"
                         Color="{StaticResource BorderColor}"
                         VerticalOptions="Fill"
                         Margin="2,2"/>
                <Button Grid.Column="5"
                        Text="✎"
                        ToolTipProperties.Text="Rename script"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding ScriptRenameCommand}"/>
                <Button Grid.Column="6"
                        Text="🗑"
                        ToolTipProperties.Text="Delete script"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding ScriptDeleteCommand}"/>
                <BoxView Grid.Column="7"
                         Color="{StaticResource BorderColor}"
                         VerticalOptions="Fill"
                         Margin="2,2"/>
                <Label Grid.Column="8"
                       Text="{Binding ScriptCountText}"
                       Style="{StaticResource DimLabel}"
                       VerticalOptions="Center"
                       Margin="4,0"/>
            </Grid>
        </Border>
        <BoxView Grid.Row="1" Color="{StaticResource BorderColor}"/>

        <!-- ── Body ─────────────────────────────────────────────── -->
        <Grid Grid.Row="2" ColumnDefinitions="180,1,*" ColumnSpacing="0">

            <!-- Folder tree -->
            <CollectionView Grid.Column="0"
                            ItemsSource="{Binding FolderItems}"
                            SelectionMode="None"
                            BackgroundColor="{StaticResource BgPanel}">
                <FlyoutBase.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="📁 New folder"
                                        Command="{Binding NewFolderCommand}"/>
                        <MenuFlyoutItem Text="New script"
                                        Command="{Binding NewScriptCommand}"/>
                    </MenuFlyout>
                </FlyoutBase.ContextFlyout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:FolderItem">
                        <Grid Padding="{Binding LeftPadding}" ColumnDefinitions="14,*" ColumnSpacing="2">
                            <FlyoutBase.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="📁 New folder"
                                                    Command="{Binding Vm.NewFolderCommand, Source={x:Reference Root}}"/>
                                    <MenuFlyoutItem Text="New script"
                                                    Command="{Binding Vm.NewScriptCommand, Source={x:Reference Root}}"/>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="✎ Rename folder"
                                                    IsEnabled="{Binding IsNotRoot}"
                                                    Command="{Binding RenameCommand}"/>
                                    <MenuFlyoutItem Text="🗑 Delete folder"
                                                    IsEnabled="{Binding IsNotRoot}"
                                                    Command="{Binding DeleteCommand}"/>
                                </MenuFlyout>
                            </FlyoutBase.ContextFlyout>
                            <Label Grid.Column="0"
                                   Text="{Binding ExpandIcon}"
                                   TextColor="{StaticResource TextMuted}"
                                   FontSize="10"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleExpandCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Grid.Column="1"
                                   Text="{Binding Name}"
                                   Style="{StaticResource PrimaryLabel}"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleExpandCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <BoxView Grid.Column="1" Color="{StaticResource BorderColor}"/>

            <!-- Script file list -->
            <CollectionView Grid.Column="2"
                            ItemsSource="{Binding ScriptItems}"
                            SelectionMode="None"
                            BackgroundColor="{StaticResource BgPanel}">
                <FlyoutBase.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="📁 New folder"
                                        Command="{Binding NewFolderCommand}"/>
                        <MenuFlyoutItem Text="New script"
                                        Command="{Binding NewScriptCommand}"/>
                    </MenuFlyout>
                </FlyoutBase.ContextFlyout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:ScriptItem">
                        <Label Text="{Binding FileName}"
                               Style="{StaticResource PrimaryLabel}"
                               Padding="10,5">
                            <FlyoutBase.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="📁 New folder"
                                                    Command="{Binding Vm.NewFolderCommand, Source={x:Reference Root}}"/>
                                    <MenuFlyoutItem Text="New script"
                                                    Command="{Binding Vm.NewScriptCommand, Source={x:Reference Root}}"/>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="✎ Rename script"
                                                    Command="{Binding RenameCommand}"/>
                                    <MenuFlyoutItem Text="🗑 Delete script"
                                                    Command="{Binding DeleteCommand}"/>
                                </MenuFlyout>
                            </FlyoutBase.ContextFlyout>
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding TapCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Text="No scripts in folder"
                           Style="{StaticResource PlaceholderLabel}"
                           Margin="0,16"/>
                </CollectionView.EmptyView>
            </CollectionView>

        </Grid>
    </Grid>
</ContentView>
