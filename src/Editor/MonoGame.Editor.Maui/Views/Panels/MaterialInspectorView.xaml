<?xml version="1.0" encoding="utf-8"?>
<ContentView x:Class="MonoGame.Editor.Maui.Views.Panels.MaterialInspectorView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="{StaticResource PanelBackground}">

    <Grid RowDefinitions="*,1,28" RowSpacing="0">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- ── Fixed fields ─────────────────────────────── -->
                <Border BackgroundColor="{StaticResource PanelBackgroundAlt}"
                        StrokeThickness="0"
                        Padding="10,4">
                    <Label Text="Material" Style="{StaticResource SectionTitle}"/>
                </Border>
                <BoxView HeightRequest="1" Color="{StaticResource Border}"/>

                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnDefinitions="70,*"
                      RowSpacing="6"
                      ColumnSpacing="8"
                      Padding="10,8">

                    <Label Grid.Row="0" Grid.Column="0"
                           Text="Name"
                           Style="{StaticResource LabelSecondary}"
                           VerticalOptions="Center"/>
                    <Entry Grid.Row="0" Grid.Column="1"
                           x:Name="MaterialNameEntry"
                           Placeholder="Material name"/>

                    <Label Grid.Row="1" Grid.Column="0"
                           Text="Shader"
                           Style="{StaticResource LabelSecondary}"
                           VerticalOptions="Center"/>
                    <Picker Grid.Row="1" Grid.Column="1"
                            x:Name="ShaderPicker"
                            SelectedIndexChanged="OnShaderPickerChanged"/>

                    <Label Grid.Row="2" Grid.Column="0"
                           Text="Mode"
                           Style="{StaticResource LabelSecondary}"
                           VerticalOptions="Center"/>
                    <Picker Grid.Row="2" Grid.Column="1"
                            x:Name="RenderingModePicker">
                        <Picker.Items>
                            <x:String>Opaque</x:String>
                            <x:String>Cutout</x:String>
                            <x:String>Fade</x:String>
                            <x:String>Transparent</x:String>
                        </Picker.Items>
                    </Picker>

                    <Label Grid.Row="3" Grid.Column="0"
                           Text="UV Set"
                           Style="{StaticResource LabelSecondary}"
                           VerticalOptions="Center"/>
                    <Entry Grid.Row="3" Grid.Column="1"
                           x:Name="UVSetEntry"
                           Keyboard="Numeric"
                           Text="0"/>

                </Grid>

                <BoxView HeightRequest="1" Color="{StaticResource Border}"/>

                <!-- ── Dynamic properties ───────────────────────── -->
                <Border BackgroundColor="{StaticResource PanelBackgroundAlt}"
                        StrokeThickness="0"
                        Padding="10,4">
                    <Label Text="Properties" Style="{StaticResource SectionTitle}"/>
                </Border>
                <BoxView HeightRequest="1" Color="{StaticResource Border}"/>

                <VerticalStackLayout x:Name="PropsStack" Padding="10,6" Spacing="6"/>

            </VerticalStackLayout>
        </ScrollView>

        <BoxView Grid.Row="1" Color="{StaticResource Border}"/>

        <!-- ── Footer ───────────────────────────────────────────── -->
        <Border Grid.Row="2"
                BackgroundColor="{StaticResource PanelBackgroundAlt}"
                StrokeThickness="0"
                Padding="8,0">
            <Grid ColumnDefinitions="*,Auto">
                <Label x:Name="MaterialStatusLabel"
                       Grid.Column="0"
                       Text=""
                       Style="{StaticResource LabelSecondary}"
                       VerticalOptions="Center"/>
                <Button Grid.Column="1"
                        x:Name="MaterialSaveButton"
                        Text="Save"
                        Style="{StaticResource SmallIconButton}"
                        IsEnabled="False"
                        Clicked="OnSaveClicked"/>
            </Grid>
        </Border>

    </Grid>
</ContentView>
