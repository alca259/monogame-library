<?xml version="1.0" encoding="utf-8"?>
<ContentView x:Class="MonoGame.Editor.Maui.Views.Panels.AssetBrowserView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="{StaticResource BgPanel}">

    <Grid RowDefinitions="28,1,*,1,24" RowSpacing="0">

        <!-- ── Toolbar ──────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4" Padding="4,2">

                <Entry Grid.Column="0"
                       x:Name="AssetSearchEntry"
                       Placeholder="Filter assets…"
                       Style="{StaticResource InputEntry}"
                       TextChanged="OnFilterChanged"/>

                <Label Grid.Column="1"
                       x:Name="AssetCountLabel"
                       Text="0 assets"
                       Style="{StaticResource DimLabel}"
                       VerticalOptions="Center"
                       Margin="4,0"/>
            </Grid>
        </Border>
        <BoxView Grid.Row="1" Color="{StaticResource BorderColor}"/>

        <!-- ── Asset list ────────────────────────────────────────── -->
        <CollectionView Grid.Row="2"
                        x:Name="AssetList"
                        SelectionMode="Single"
                        SelectionChanged="OnAssetSelectionChanged"
                        BackgroundColor="{StaticResource BgPanel}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Grid Padding="10,3">
                        <Label Text="{Binding .}"
                               Style="{StaticResource PrimaryLabel}"
                               VerticalOptions="Center"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="No project open"
                       Style="{StaticResource PlaceholderLabel}"
                       Margin="0,24"/>
            </CollectionView.EmptyView>
        </CollectionView>

        <BoxView Grid.Row="3" Color="{StaticResource BorderColor}"/>

        <!-- ── Status footer ─────────────────────────────────────── -->
        <Border Grid.Row="4"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0"
                Padding="8,0">
            <Label x:Name="AssetPathLabel"
                   Text=""
                   Style="{StaticResource DimLabel}"
                   VerticalOptions="Center"/>
        </Border>

    </Grid>
</ContentView>
