<?xml version="1.0" encoding="utf-8"?>
<ContentView x:Class="MonoGame.Editor.Maui.Views.Panels.AssetBrowserView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MonoGame.Editor.Maui.Views.Panels"
             xmlns:vm="clr-namespace:MonoGame.Editor.Maui.ViewModels.Panels"
             x:DataType="vm:AssetBrowserViewModel"
             BackgroundColor="{StaticResource BgPanel}">

    <Grid RowDefinitions="28,1,*,1,24" RowSpacing="0">

        <!-- ── Toolbar ──────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,1,Auto,*,Auto" ColumnSpacing="4" Padding="4,2">

                <Button Grid.Column="0"
                        Text="⬆"
                        ToolTipProperties.Text="Import asset"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding ImportAssetCommand}"/>
                <Button Grid.Column="1"
                        Text="✎"
                        ToolTipProperties.Text="Rename selected"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding AssetRenameCommand}"/>
                <Button Grid.Column="2"
                        Text="🗑"
                        ToolTipProperties.Text="Delete selected"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding AssetDeleteCommand}"/>

                <BoxView Grid.Column="3"
                         Color="{StaticResource BorderColor}"
                         VerticalOptions="Fill"
                         Margin="2,2"/>

                <Button Grid.Column="4"
                        Text="📁"
                        ToolTipProperties.Text="New folder"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding NewFolderCommand}"/>

                <BoxView Grid.Column="5"
                         Color="{StaticResource BorderColor}"
                         VerticalOptions="Fill"
                         Margin="2,2"/>

                <Entry Grid.Column="6"
                       Placeholder="Filter assets…"
                       Style="{StaticResource InputEntry}"
                       Text="{Binding FilterText}"/>

                <Label Grid.Column="7"
                       Text="{Binding AssetCountText}"
                       Style="{StaticResource DimLabel}"
                       VerticalOptions="Center"
                       Margin="4,0"/>
            </Grid>
        </Border>
        <BoxView Grid.Row="1" Color="{StaticResource BorderColor}"/>

        <!-- ── Body: folder tree | asset panel ──────────────────── -->
        <Grid Grid.Row="2"
              ColumnDefinitions="200,1,*"
              ColumnSpacing="0">

            <!-- Folder tree -->
            <CollectionView Grid.Column="0"
                            ItemsSource="{Binding FolderItems}"
                            SelectionMode="None"
                            BackgroundColor="{StaticResource BgPanel}">
                <FlyoutBase.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="📁 New folder"
                                        Command="{Binding NewFolderCommand}"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutSubItem Text="New asset">
                            <MenuFlyoutItem Text="◈ Material"
                                            Command="{Binding NewMaterialCommand}"/>
                            <MenuFlyoutItem Text="◧ UI Theme"
                                            Command="{Binding NewUIThemeCommand}"/>
                            <MenuFlyoutItem Text="✦ Sprite NineSlice"
                                            Command="{Binding NewSpriteCommand}"/>
                        </MenuFlyoutSubItem>
                    </MenuFlyout>
                </FlyoutBase.ContextFlyout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:FolderItem">
                        <Grid ColumnDefinitions="14,*"
                              Padding="{Binding LeftPadding}"
                              ColumnSpacing="2">
                            <FlyoutBase.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="📁 New folder"
                                                    Command="{Binding Vm.NewFolderCommand, Source={x:Reference Root}}"/>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutSubItem Text="New asset">
                                        <MenuFlyoutItem Text="◈ Material"
                                                        Command="{Binding Vm.NewMaterialCommand, Source={x:Reference Root}}"/>
                                        <MenuFlyoutItem Text="◧ UI Theme"
                                                        Command="{Binding Vm.NewUIThemeCommand, Source={x:Reference Root}}"/>
                                        <MenuFlyoutItem Text="✦ Sprite NineSlice"
                                                        Command="{Binding Vm.NewSpriteCommand, Source={x:Reference Root}}"/>
                                    </MenuFlyoutSubItem>
                                    <MenuFlyoutSeparator/>
                                    <MenuFlyoutItem Text="✎ Rename folder"
                                                    IsEnabled="{Binding IsNotRoot}"
                                                    Command="{Binding RenameCommand}"/>
                                    <MenuFlyoutItem Text="🗑 Delete folder"
                                                    IsEnabled="{Binding IsNotRoot}"
                                                    Command="{Binding DeleteCommand}"/>
                                </MenuFlyout>
                            </FlyoutBase.ContextFlyout>
                            <Label Grid.Column="0"
                                   Text="{Binding ExpandIcon}"
                                   Style="{StaticResource DimLabel}"
                                   FontSize="10"
                                   VerticalOptions="Center"
                                   HorizontalTextAlignment="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleExpandCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Grid.Column="1"
                                   Text="{Binding Name}"
                                   Style="{StaticResource PrimaryLabel}"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleExpandCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Text="No project open"
                           Style="{StaticResource PlaceholderLabel}"
                           Margin="8,12"/>
                </CollectionView.EmptyView>
            </CollectionView>

            <BoxView Grid.Column="1" Color="{StaticResource BorderColor}"/>

            <!-- Right panel: breadcrumb + column headers + asset list -->
            <Grid Grid.Column="2"
                  RowDefinitions="Auto,1,24,1,*"
                  RowSpacing="0">

                <!-- Breadcrumb (built in code-behind from VM.CurrentFolderPath) -->
                <ScrollView Grid.Row="0"
                            Orientation="Horizontal"
                            HeightRequest="26"
                            BackgroundColor="{StaticResource BgChrome}">
                    <HorizontalStackLayout x:Name="BreadcrumbLayout"
                                           Spacing="0"
                                           VerticalOptions="Center"
                                           Padding="4,0"/>
                </ScrollView>
                <BoxView Grid.Row="1" Color="{StaticResource BorderColor}"/>

                <!-- Column headers -->
                <Grid Grid.Row="2"
                      ColumnDefinitions="24,*,80,60"
                      BackgroundColor="{StaticResource BgChrome}"
                      Padding="8,0"
                      ColumnSpacing="4">
                    <Label Grid.Column="1" Text="Name" Style="{StaticResource DimLabel}" VerticalOptions="Center"/>
                    <Label Grid.Column="2" Text="Type" Style="{StaticResource DimLabel}" VerticalOptions="Center"/>
                    <Label Grid.Column="3" Text="Size" Style="{StaticResource DimLabel}" VerticalOptions="Center"/>
                </Grid>
                <BoxView Grid.Row="3" Color="{StaticResource BorderColor}"/>

                <!-- Asset list -->
                <CollectionView Grid.Row="4"
                                ItemsSource="{Binding AssetItems}"
                                SelectedItem="{Binding SelectedAsset}"
                                SelectionMode="Single"
                                BackgroundColor="{StaticResource BgPanel}">
                    <FlyoutBase.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="📁 New folder"
                                            Command="{Binding NewFolderCommand}"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutSubItem Text="New asset">
                                <MenuFlyoutItem Text="◈ Material"
                                                Command="{Binding NewMaterialCommand}"/>
                                <MenuFlyoutItem Text="◧ UI Theme"
                                                Command="{Binding NewUIThemeCommand}"/>
                                <MenuFlyoutItem Text="✦ Sprite NineSlice"
                                                Command="{Binding NewSpriteCommand}"/>
                            </MenuFlyoutSubItem>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem Text="✎ Rename"
                                            Command="{Binding AssetRenameCommand}"/>
                            <MenuFlyoutItem Text="🗑 Delete"
                                            Command="{Binding AssetDeleteCommand}"/>
                        </MenuFlyout>
                    </FlyoutBase.ContextFlyout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="local:AssetItem">
                            <Grid ColumnDefinitions="24,*,80,60"
                                  Padding="8,2"
                                  ColumnSpacing="4">
                                <Label Grid.Column="0"
                                       Text="{Binding Icon}"
                                       FontSize="13"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="1"
                                       Text="{Binding Info.Name}"
                                       Style="{StaticResource PrimaryLabel}"
                                       VerticalOptions="Center"/>
                                <Label Grid.Column="2"
                                       Text="{Binding TypeLabel}"
                                       Style="{StaticResource DimLabel}"
                                       VerticalOptions="Center"/>
                                <Label Grid.Column="3"
                                       Text="{Binding SizeLabel}"
                                       Style="{StaticResource DimLabel}"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label Text="Empty folder"
                               Style="{StaticResource PlaceholderLabel}"
                               Margin="0,24"/>
                    </CollectionView.EmptyView>
                </CollectionView>

            </Grid>
        </Grid>

        <BoxView Grid.Row="3" Color="{StaticResource BorderColor}"/>

        <!-- ── Status footer ─────────────────────────────────────── -->
        <Border Grid.Row="4"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0"
                Padding="8,0">
            <Label Text="{Binding AssetPathText}"
                   Style="{StaticResource DimLabel}"
                   VerticalOptions="Center"/>
        </Border>

    </Grid>
</ContentView>
