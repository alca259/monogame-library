<?xml version="1.0" encoding="utf-8"?>
<ContentView x:Class="MonoGame.Editor.Maui.Views.Panels.UndoHistoryView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="{StaticResource BgPanel}">

    <Grid RowDefinitions="28,1,*" RowSpacing="0">

        <!-- ── Toolbar ──────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4" Padding="4,2">
                <Button Grid.Column="0"
                        Text="✕ Clear"
                        Style="{StaticResource SmallIconButton}"
                        Clicked="OnClearClicked"/>
                <Label Grid.Column="1"
                       x:Name="HistorySummaryLabel"
                       Text="0 / 100"
                       Style="{StaticResource DimLabel}"
                       VerticalOptions="Center"
                       Margin="4,0"/>
            </Grid>
        </Border>
        <BoxView Grid.Row="1" Color="{StaticResource BorderColor}"/>

        <!-- ── History rows (built in code-behind) ──────────────── -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout x:Name="HistoryStack" Spacing="0"/>
        </ScrollView>

    </Grid>
</ContentView>
