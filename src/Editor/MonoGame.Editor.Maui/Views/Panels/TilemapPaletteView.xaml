<?xml version="1.0" encoding="utf-8"?>
<ContentView x:Class="MonoGame.Editor.Maui.Views.Panels.TilemapPaletteView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MonoGame.Editor.Maui.ViewModels.Panels"
             x:DataType="vm:TilemapPaletteViewModel"
             BackgroundColor="{StaticResource BgPanel}">

    <Grid RowDefinitions="28,1,24,1,*" RowSpacing="0">

        <!-- ── Toolbar ──────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="4" Padding="4,2">
                <Label Grid.Column="0"
                       Text="{Binding TilemapInfoText}"
                       Style="{StaticResource DimLabel}"
                       VerticalOptions="Center"/>
                <Button Grid.Column="1"
                        Text="Paint"
                        Style="{StaticResource ActivePillButton}"
                        Command="{Binding PaintModeCommand}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsEraseMode}" Value="True">
                            <Setter Property="Style" Value="{StaticResource PillButton}"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Grid.Column="2"
                        Text="Erase"
                        Style="{StaticResource PillButton}"
                        Command="{Binding EraseModeCommand}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsEraseMode}" Value="True">
                            <Setter Property="Style" Value="{StaticResource ActivePillButton}"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>
        </Border>
        <BoxView Grid.Row="1" Color="{StaticResource BorderColor}"/>

        <!-- ── Tile count / selection info ──────────────────────── -->
        <Border Grid.Row="2"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0"
                Padding="8,0">
            <Label Text="{Binding TileCountText}"
                   Style="{StaticResource DimLabel}"
                   VerticalOptions="Center"/>
        </Border>
        <BoxView Grid.Row="3" Color="{StaticResource BorderColor}"/>

        <!-- ── Palette canvas (drawn in code-behind) ────────────── -->
        <ScrollView Grid.Row="4" Orientation="Vertical">
            <Grid>
                <GraphicsView x:Name="PaletteCanvas"
                              BackgroundColor="{StaticResource BgPanel}">
                    <GraphicsView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPaletteTapped"/>
                    </GraphicsView.GestureRecognizers>
                </GraphicsView>
                <Label Text="Open a project and select a tilemap layer"
                       IsVisible="{Binding PlaceholderVisible}"
                       Style="{StaticResource PlaceholderLabel}"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"/>
            </Grid>
        </ScrollView>

    </Grid>
</ContentView>
