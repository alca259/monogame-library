<?xml version="1.0" encoding="utf-8"?>
<ContentView x:Class="MonoGame.Editor.Maui.Views.Panels.LocalizationBrowserView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MonoGame.Editor.Maui.ViewModels.Panels"
             x:DataType="vm:LocalizationBrowserViewModel"
             BackgroundColor="{StaticResource BgPanel}">

    <Grid RowDefinitions="28,1,*,1,24" RowSpacing="0">

        <!-- ── Toolbar ──────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,1,*,Auto" ColumnSpacing="2" Padding="4,2">
                <Button Grid.Column="0"
                        Text="+ Key"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding AddKeyCommand}"/>
                <Button Grid.Column="1"
                        Text="+ Locale"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding AddLocaleCommand}"/>
                <Button Grid.Column="2"
                        Text="🗑 Key"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding RemoveKeyCommand}"/>
                <Button Grid.Column="3"
                        Text="🗑 Locale"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding RemoveLocaleCommand}"/>
                <BoxView Grid.Column="4"
                         Color="{StaticResource BorderColor}"
                         VerticalOptions="Fill"
                         Margin="2,2"/>
                <Label Grid.Column="5"
                       Text="{Binding LocaleCountText}"
                       Style="{StaticResource DimLabel}"
                       VerticalOptions="Center"
                       Margin="4,0"/>
                <Button Grid.Column="6"
                        Text="Save"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding SaveCommand}"/>
            </Grid>
        </Border>
        <BoxView Grid.Row="1" Color="{StaticResource BorderColor}"/>

        <!-- ── Body ─────────────────────────────────────────────── -->
        <Grid Grid.Row="2" ColumnDefinitions="180,1,*" ColumnSpacing="0">

            <!-- Keys list -->
            <CollectionView Grid.Column="0"
                            ItemsSource="{Binding KeyItems}"
                            SelectedItem="{Binding SelectedKey}"
                            SelectionMode="Single"
                            BackgroundColor="{StaticResource BgPanel}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Label Text="{Binding .}"
                               Style="{StaticResource PrimaryLabel}"
                               Padding="10,5"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Text="No keys"
                           Style="{StaticResource PlaceholderLabel}"
                           Margin="0,16"/>
                </CollectionView.EmptyView>
            </CollectionView>

            <BoxView Grid.Column="1" Color="{StaticResource BorderColor}"/>

            <!-- Translation entries (one editable field per locale) -->
            <ScrollView Grid.Column="2">
                <VerticalStackLayout Padding="10,8" Spacing="6"
                                     BindableLayout.ItemsSource="{Binding Translations}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:LocaleValueItem">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding Locale}"
                                       FontSize="11"
                                       TextColor="#9A9AA2"/>
                                <Entry Text="{Binding Value}"
                                       Style="{StaticResource InputEntry}"/>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </ScrollView>

        </Grid>

        <BoxView Grid.Row="3" Color="{StaticResource BorderColor}"/>

        <!-- ── Status footer ────────────────────────────────────── -->
        <Border Grid.Row="4"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0"
                Padding="8,0">
            <Label Text="{Binding StatusText}"
                   Style="{StaticResource DimLabel}"
                   VerticalOptions="Center"/>
        </Border>

    </Grid>
</ContentView>
