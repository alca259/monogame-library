<?xml version="1.0" encoding="utf-8"?>
<ContentView x:Class="MonoGame.Editor.Maui.Views.Panels.UIThemeInspectorView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MonoGame.Editor.Maui.ViewModels.Panels"
             x:DataType="vm:UIThemeInspectorViewModel"
             BackgroundColor="{StaticResource PanelBackground}">

    <Grid RowDefinitions="*,1,28" RowSpacing="0">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Theme name -->
                <Border BackgroundColor="{StaticResource PanelBackgroundAlt}"
                        StrokeThickness="0"
                        Padding="10,6">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label Grid.Column="0"
                               Text="Name"
                               Style="{StaticResource LabelSecondary}"
                               VerticalOptions="Center"/>
                        <Entry Grid.Column="1"
                               Text="{Binding ThemeName}"
                               Placeholder="Theme name"/>
                    </Grid>
                </Border>
                <BoxView HeightRequest="1" Color="{StaticResource Border}"/>

                <!-- Control sections (Panel / Button / Dropdown / ProgressBar / TextBox) -->
                <VerticalStackLayout Spacing="0"
                                     BindableLayout.ItemsSource="{Binding Sections}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:UIThemeSectionViewModel">
                            <VerticalStackLayout Spacing="0">
                                <Label Text="{Binding Name}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       Padding="10,6"
                                       BackgroundColor="#252528"/>
                                <VerticalStackLayout Padding="10,4,10,2" Spacing="2">
                                    <Label Text="Texture Path"
                                           FontSize="10"
                                           TextColor="#9A9AA2"/>
                                    <Entry Text="{Binding TexturePath}"
                                           Placeholder="path/to/texture"/>
                                    <Label Text="L / R / T / B"
                                           FontSize="10"
                                           TextColor="#9A9AA2"
                                           Margin="0,4,0,0"/>
                                </VerticalStackLayout>
                                <Grid ColumnDefinitions="*,*,*,*"
                                      ColumnSpacing="6"
                                      Padding="10,0,10,4">
                                    <Entry Grid.Column="0" Keyboard="Numeric" Text="{Binding Left}"/>
                                    <Entry Grid.Column="1" Keyboard="Numeric" Text="{Binding Right}"/>
                                    <Entry Grid.Column="2" Keyboard="Numeric" Text="{Binding Top}"/>
                                    <Entry Grid.Column="3" Keyboard="Numeric" Text="{Binding Bottom}"/>
                                </Grid>
                                <HorizontalStackLayout Spacing="8" Padding="10,0,10,6">
                                    <CheckBox IsChecked="{Binding TileEdges}"/>
                                    <Label Text="Tile Edges" VerticalOptions="Center" FontSize="11"/>
                                    <CheckBox IsChecked="{Binding TileCenter}"/>
                                    <Label Text="Tile Center" VerticalOptions="Center" FontSize="11"/>
                                </HorizontalStackLayout>
                                <BoxView HeightRequest="1" Color="#3A3A3E"/>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <BoxView Grid.Row="1" Color="{StaticResource Border}"/>

        <!-- ── Footer ───────────────────────────────────────────── -->
        <Border Grid.Row="2"
                BackgroundColor="{StaticResource PanelBackgroundAlt}"
                StrokeThickness="0"
                Padding="8,0">
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="{Binding StatusText}"
                       Style="{StaticResource LabelSecondary}"
                       VerticalOptions="Center"/>
                <Button Grid.Column="1"
                        Text="Save"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding SaveCommand}"/>
            </Grid>
        </Border>

    </Grid>
</ContentView>
