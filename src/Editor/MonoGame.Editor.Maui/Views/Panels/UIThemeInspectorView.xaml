<?xml version="1.0" encoding="utf-8"?>
<ContentView x:Class="MonoGame.Editor.Maui.Views.Panels.UIThemeInspectorView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="{StaticResource PanelBackground}">

    <Grid RowDefinitions="*,1,28" RowSpacing="0">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Theme name -->
                <Border BackgroundColor="{StaticResource PanelBackgroundAlt}"
                        StrokeThickness="0"
                        Padding="10,6">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label Grid.Column="0"
                               Text="Name"
                               Style="{StaticResource LabelSecondary}"
                               VerticalOptions="Center"/>
                        <Entry Grid.Column="1"
                               x:Name="ThemeNameEntry"
                               Placeholder="Theme name"/>
                    </Grid>
                </Border>
                <BoxView HeightRequest="1" Color="{StaticResource Border}"/>

                <!-- Control sections (Panel / Button / Dropdown / ProgressBar / TextBox) -->
                <!-- Built dynamically in code-behind inside OnHandlerChanged → BuildSections() -->
                <VerticalStackLayout x:Name="ThemeStack" Spacing="0"/>

            </VerticalStackLayout>
        </ScrollView>

        <BoxView Grid.Row="1" Color="{StaticResource Border}"/>

        <!-- ── Footer ───────────────────────────────────────────── -->
        <Border Grid.Row="2"
                BackgroundColor="{StaticResource PanelBackgroundAlt}"
                StrokeThickness="0"
                Padding="8,0">
            <Grid ColumnDefinitions="*,Auto">
                <Label x:Name="ThemeStatusLabel"
                       Grid.Column="0"
                       Text=""
                       Style="{StaticResource LabelSecondary}"
                       VerticalOptions="Center"/>
                <Button Grid.Column="1"
                        x:Name="ThemeSaveButton"
                        Text="Save"
                        Style="{StaticResource SmallIconButton}"
                        IsEnabled="False"
                        Clicked="OnSaveClicked"/>
            </Grid>
        </Border>

    </Grid>
</ContentView>
