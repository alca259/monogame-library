<?xml version="1.0" encoding="utf-8"?>
<ContentView x:Class="MonoGame.Editor.Maui.Views.Panels.InspectorView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="{StaticResource BgPanel}">

    <Grid RowDefinitions="30,*" RowSpacing="0">

        <!-- ── Inspector tabs ───────────────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0">
            <HorizontalStackLayout Spacing="0">
                <Button x:Name="InspectorTabBtn"
                        Text="Inspector"
                        Style="{StaticResource InspectorTabButton}"
                        Clicked="OnInspectorTabClicked"/>
                <Button x:Name="MaterialTabBtn"
                        Text="Material Editor"
                        Style="{StaticResource InspectorTabButton}"
                        Clicked="OnMaterialTabClicked"/>
                <Button x:Name="UIThemeTabBtn"
                        Text="UI Theme Editor"
                        Style="{StaticResource InspectorTabButton}"
                        Clicked="OnUIThemeTabClicked"/>
            </HorizontalStackLayout>
        </Border>
        <!-- Tabs bottom separator -->
        <BoxView Grid.Row="0" VerticalOptions="End"
                 HeightRequest="1" Color="{StaticResource BorderColor}"/>

        <!-- ── Tab content area ─────────────────────────────────── -->
        <Grid Grid.Row="1">

            <!-- ── Inspector tab content ─────────────────────────── -->
            <ScrollView x:Name="InspectorContent"
                        BackgroundColor="{StaticResource BgPanel}">
                <VerticalStackLayout Spacing="0">

                    <!-- No selection placeholder -->
                    <Label x:Name="NoSelectionLabel"
                           Text="No object selected"
                           Style="{StaticResource PlaceholderLabel}"
                           Margin="0,48"
                           IsVisible="True"/>

                    <!-- Object header (shown when an object is selected) -->
                    <Border x:Name="ObjectHeader"
                            BackgroundColor="{StaticResource BgRaised}"
                            StrokeThickness="0"
                            Padding="10,8"
                            IsVisible="False">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <CheckBox Grid.Column="0"
                                      x:Name="ObjectActiveCheck"
                                      Color="{StaticResource AccentBlue}"
                                      CheckedChanged="OnObjectActiveChanged"/>
                            <Label Grid.Column="1"
                                   x:Name="ObjectNameLabel"
                                   Text="GameObject"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"/>
                            <Border Grid.Column="2"
                                    BackgroundColor="{StaticResource BgInput}"
                                    StrokeThickness="0"
                                    Padding="6,2">
                                <Label x:Name="ObjectIdLabel"
                                       Text="--------"
                                       Style="{StaticResource MonoLabel}"
                                       VerticalOptions="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Transform section -->
                    <Border x:Name="TransformSection"
                            BackgroundColor="{StaticResource BgPanel}"
                            StrokeThickness="0"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="0">

                            <!-- Section header -->
                            <Grid ColumnDefinitions="20,*"
                                  BackgroundColor="{StaticResource BgChrome}"
                                  Padding="8,4">
                                <Label Grid.Column="0"
                                       x:Name="TransformChevron"
                                       Text="▼"
                                       TextColor="{StaticResource TextDim}"
                                       FontSize="10"
                                       VerticalOptions="Center"/>
                                <Label Grid.Column="1"
                                       Text="Transform"
                                       Style="{StaticResource PanelTitleLabel}"
                                       VerticalOptions="Center"/>
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource BorderColor}"/>

                            <!-- Transform fields -->
                            <Grid Padding="10,8" RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="70,*,*" RowSpacing="6" ColumnSpacing="6">

                                <!-- Position -->
                                <Label Grid.Row="0" Grid.Column="0" Text="Position"
                                       Style="{StaticResource SecondaryLabel}" VerticalOptions="Center"/>
                                <Entry Grid.Row="0" Grid.Column="1" x:Name="PosXEntry"
                                       Placeholder="X" Style="{StaticResource InputEntry}"
                                       TextChanged="OnTransformChanged"/>
                                <Entry Grid.Row="0" Grid.Column="2" x:Name="PosYEntry"
                                       Placeholder="Y" Style="{StaticResource InputEntry}"
                                       TextChanged="OnTransformChanged"/>

                                <!-- Rotation -->
                                <Label Grid.Row="1" Grid.Column="0" Text="Rotation"
                                       Style="{StaticResource SecondaryLabel}" VerticalOptions="Center"/>
                                <Entry Grid.Row="1" Grid.Column="1" x:Name="RotZEntry"
                                       Placeholder="Z" Style="{StaticResource InputEntry}"
                                       TextChanged="OnTransformChanged"/>

                                <!-- Scale -->
                                <Label Grid.Row="2" Grid.Column="0" Text="Scale"
                                       Style="{StaticResource SecondaryLabel}" VerticalOptions="Center"/>
                                <Entry Grid.Row="2" Grid.Column="1" x:Name="ScaleXEntry"
                                       Placeholder="X" Style="{StaticResource InputEntry}"
                                       TextChanged="OnTransformChanged"/>
                                <Entry Grid.Row="2" Grid.Column="2" x:Name="ScaleYEntry"
                                       Placeholder="Y" Style="{StaticResource InputEntry}"
                                       TextChanged="OnTransformChanged"/>

                                <!-- Depth -->
                                <Label Grid.Row="3" Grid.Column="0" Text="Depth"
                                       Style="{StaticResource SecondaryLabel}" VerticalOptions="Center"/>
                                <Entry Grid.Row="3" Grid.Column="1" x:Name="DepthEntry"
                                       Placeholder="Z" Style="{StaticResource InputEntry}"
                                       TextChanged="OnTransformChanged"/>
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource BorderColor}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Behaviour cards placeholder -->
                    <Label x:Name="AddBehaviourBtn"
                           Text="+ Add Behaviour…"
                           TextColor="{StaticResource AccentBlue}"
                           FontSize="12"
                           Margin="10,8"
                           IsVisible="False">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAddBehaviourTapped"/>
                        </Label.GestureRecognizers>
                    </Label>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ── Material Editor tab content ───────────────────── -->
            <Label x:Name="MaterialContent"
                   Text="Material Editor — Fase 7"
                   Style="{StaticResource PlaceholderLabel}"
                   IsVisible="False"/>

            <!-- ── UI Theme Editor tab content ───────────────────── -->
            <Label x:Name="UIThemeContent"
                   Text="UI Theme Editor — Fase 7"
                   Style="{StaticResource PlaceholderLabel}"
                   IsVisible="False"/>

        </Grid>
    </Grid>
</ContentView>
