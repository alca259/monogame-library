<?xml version="1.0" encoding="utf-8"?>
<ContentView x:Class="MonoGame.Editor.Maui.Views.Panels.InputMapEditorView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MonoGame.Editor.Maui.ViewModels.Panels"
             x:DataType="vm:InputMapEditorViewModel"
             BackgroundColor="{StaticResource BgPanel}">

    <Grid RowDefinitions="28,1,28,1,*" RowSpacing="0">

        <!-- ── File picker toolbar ──────────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0">
            <Grid ColumnDefinitions="*,Auto" Padding="4,2">
                <Picker Grid.Column="0"
                        Title="Select input map…"
                        ItemsSource="{Binding FileNames}"
                        SelectedIndex="{Binding SelectedFileIndex}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource TextPrimary}"
                        VerticalOptions="Center"/>
                <Button Grid.Column="1"
                        Text="Save"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding SaveCommand}"/>
            </Grid>
        </Border>
        <BoxView Grid.Row="1" Color="{StaticResource BorderColor}"/>

        <!-- ── Actions / Bindings toolbars ──────────────────────── -->
        <Border Grid.Row="2"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0">
            <Grid ColumnDefinitions="180,1,*" ColumnSpacing="0">
                <!-- Actions toolbar -->
                <HorizontalStackLayout Grid.Column="0" Spacing="2" Padding="4,2">
                    <Button Text="+"
                            ToolTipProperties.Text="Add action"
                            Style="{StaticResource SmallIconButton}"
                            Command="{Binding AddActionCommand}"/>
                    <Button Text="🗑"
                            ToolTipProperties.Text="Remove action"
                            Style="{StaticResource SmallIconButton}"
                            Command="{Binding RemoveActionCommand}"/>
                    <Label Text="Actions"
                           Style="{StaticResource DimLabel}"
                           VerticalOptions="Center"
                           Margin="4,0"/>
                </HorizontalStackLayout>
                <BoxView Grid.Column="1" Color="{StaticResource BorderColor}" VerticalOptions="Fill"/>
                <!-- Bindings toolbar -->
                <HorizontalStackLayout Grid.Column="2" Spacing="2" Padding="4,2">
                    <Button Text="+"
                            ToolTipProperties.Text="Add binding"
                            Style="{StaticResource SmallIconButton}"
                            Command="{Binding AddBindingCommand}"/>
                    <Button Text="🗑"
                            ToolTipProperties.Text="Remove binding"
                            Style="{StaticResource SmallIconButton}"
                            Command="{Binding RemoveBindingCommand}"/>
                    <Label Text="Bindings"
                           Style="{StaticResource DimLabel}"
                           VerticalOptions="Center"
                           Margin="4,0"/>
                </HorizontalStackLayout>
            </Grid>
        </Border>
        <BoxView Grid.Row="3" Color="{StaticResource BorderColor}"/>

        <!-- ── Body ─────────────────────────────────────────────── -->
        <Grid Grid.Row="4" ColumnDefinitions="180,1,*" ColumnSpacing="0">

            <CollectionView Grid.Column="0"
                            ItemsSource="{Binding ActionItems}"
                            SelectedItem="{Binding SelectedAction}"
                            SelectionMode="Single"
                            BackgroundColor="{StaticResource BgPanel}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Label Text="{Binding .}"
                               Style="{StaticResource PrimaryLabel}"
                               Padding="10,5"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Text="No actions"
                           Style="{StaticResource PlaceholderLabel}"
                           Margin="0,16"/>
                </CollectionView.EmptyView>
            </CollectionView>

            <BoxView Grid.Column="1" Color="{StaticResource BorderColor}"/>

            <CollectionView Grid.Column="2"
                            ItemsSource="{Binding BindingItems}"
                            SelectedItem="{Binding SelectedBinding}"
                            SelectionMode="Single"
                            BackgroundColor="{StaticResource BgPanel}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Label Text="{Binding .}"
                               Style="{StaticResource PrimaryLabel}"
                               Padding="10,5"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Text="Select an action"
                           Style="{StaticResource PlaceholderLabel}"
                           Margin="0,16"/>
                </CollectionView.EmptyView>
            </CollectionView>

        </Grid>
    </Grid>
</ContentView>
