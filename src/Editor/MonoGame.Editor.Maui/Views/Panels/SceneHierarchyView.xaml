<?xml version="1.0" encoding="utf-8"?>
<ContentView x:Class="MonoGame.Editor.Maui.Views.Panels.SceneHierarchyView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MonoGame.Editor.Maui.Views.Panels"
             BackgroundColor="{StaticResource BgPanel}">

    <Grid RowDefinitions="28,*,24" RowSpacing="0">

        <!-- ── Toolbar ──────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0">
            <Grid ColumnDefinitions="Auto,Auto,Auto,1,*,Auto" ColumnSpacing="2" Padding="4,2">

                <Button Grid.Column="0"
                        Text="+"
                        ToolTipProperties.Text="Create empty entity"
                        Style="{StaticResource SmallIconButton}"
                        Clicked="OnAddClicked"/>

                <Button Grid.Column="1"
                        Text="🗑"
                        ToolTipProperties.Text="Delete selected entity"
                        Style="{StaticResource SmallIconButton}"
                        Clicked="OnDeleteClicked"/>

                <Button Grid.Column="2"
                        x:Name="RenameBtn"
                        Text="✎"
                        ToolTipProperties.Text="Rename selected entity"
                        Style="{StaticResource SmallIconButton}"
                        IsEnabled="False"
                        Clicked="OnRenameClicked"/>

                <BoxView Grid.Column="3"
                         Color="{StaticResource BorderColor}"
                         VerticalOptions="Fill"
                         Margin="2,2"/>

                <Entry Grid.Column="4"
                       x:Name="SearchEntry"
                       Placeholder="Search…"
                       Style="{StaticResource InputEntry}"
                       TextChanged="OnSearchTextChanged"/>

                <Label Grid.Column="5"
                       x:Name="CountLabel"
                       Text="0 entities"
                       Style="{StaticResource DimLabel}"
                       VerticalOptions="Center"
                       Margin="4,0"/>
            </Grid>
        </Border>
        <!-- Toolbar bottom separator -->
        <BoxView Grid.Row="0" VerticalOptions="End"
                 HeightRequest="1" Color="{StaticResource BorderColor}"/>

        <!-- ── Entity tree ───────────────────────────────────────── -->
        <CollectionView Grid.Row="1"
                        x:Name="HierarchyList"
                        SelectionMode="Single"
                        SelectionChanged="OnSelectionChanged"
                        BackgroundColor="{StaticResource BgPanel}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:HierarchyItem">
                    <Grid ColumnDefinitions="Auto,*"
                          Padding="{Binding LeftPadding}">

                        <!-- Expand / collapse icon (tap = toggle, also selects row) -->
                        <Label Grid.Column="0"
                               Text="{Binding ExpandIcon}"
                               TextColor="{StaticResource TextDim}"
                               FontSize="10"
                               WidthRequest="16"
                               HorizontalTextAlignment="Center"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleExpandCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>

                        <!-- Name label: single tap → selection (via CollectionView),
                                         double tap → inline rename -->
                        <Label Grid.Column="1"
                               Text="{Binding DisplayName}"
                               TextColor="{Binding NameColor}"
                               FontSize="12"
                               VerticalOptions="Center"
                               Margin="2,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer NumberOfTapsRequired="2"
                                                      Command="{Binding RenameCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="Empty scene"
                       Style="{StaticResource PlaceholderLabel}"
                       Margin="0,24"/>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- ── Status footer ─────────────────────────────────────── -->
        <Border Grid.Row="2"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0"
                Padding="8,0">
            <Label x:Name="StatusLabel"
                   Text="0 objects in scene"
                   Style="{StaticResource DimLabel}"
                   VerticalOptions="Center"/>
        </Border>
        <!-- Footer top separator -->
        <BoxView Grid.Row="2" VerticalOptions="Start"
                 HeightRequest="1" Color="{StaticResource BorderColor}"/>

    </Grid>
</ContentView>
