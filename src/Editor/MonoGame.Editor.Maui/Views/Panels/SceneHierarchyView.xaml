<?xml version="1.0" encoding="utf-8"?>
<ContentView x:Class="MonoGame.Editor.Maui.Views.Panels.SceneHierarchyView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MonoGame.Editor.Maui.Views.Panels"
             xmlns:vm="clr-namespace:MonoGame.Editor.Maui.ViewModels.Panels"
             xmlns:controls="clr-namespace:MonoGame.Editor.Maui.Controls"
             x:DataType="vm:SceneHierarchyViewModel"
             BackgroundColor="{StaticResource BgPanel}">

    <ContentView.Behaviors>
        <controls:FocusOnClickBehavior Context="Hierarchy"/>
    </ContentView.Behaviors>

    <Grid>
    <Grid RowDefinitions="28,*,24" RowSpacing="0">

        <!-- ── Toolbar ──────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,1,*,Auto" ColumnSpacing="2" Padding="4,2">

                <Button Grid.Column="0"
                        Text="+"
                        ToolTipProperties.Text="Create empty entity"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding AddEntityCommand}"/>

                <Button Grid.Column="1"
                        Text="🗑"
                        ToolTipProperties.Text="Delete selected entity"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding DeleteEntityCommand}"/>

                <Button Grid.Column="2"
                        Text="✎"
                        ToolTipProperties.Text="Rename selected entity"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding RenameCommand}"/>

                <Button Grid.Column="3"
                        Text="↑"
                        ToolTipProperties.Text="Reparent selected entity"
                        Style="{StaticResource SmallIconButton}"
                        Command="{Binding ReparentCommand}"/>

                <BoxView Grid.Column="4"
                         Color="{StaticResource BorderColor}"
                         VerticalOptions="Fill"
                         Margin="2,2"/>

                <Entry Grid.Column="5"
                       Placeholder="Search…"
                       Style="{StaticResource InputEntry}"
                       Text="{Binding SearchFilter}"/>

                <Label Grid.Column="6"
                       Text="{Binding CountText}"
                       Style="{StaticResource DimLabel}"
                       VerticalOptions="Center"
                       Margin="4,0"/>
            </Grid>
        </Border>
        <!-- Toolbar bottom separator -->
        <BoxView Grid.Row="0" VerticalOptions="End"
                 HeightRequest="1" Color="{StaticResource BorderColor}"/>

        <!-- ── Entity tree ───────────────────────────────────────── -->
        <CollectionView Grid.Row="1"
                        x:Name="EntityList"
                        ItemsSource="{Binding Items}"
                        SelectedItem="{Binding SelectedItem}"
                        SelectionMode="Single"
                        BackgroundColor="{StaticResource BgPanel}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:HierarchyItem">
                    <Grid ColumnDefinitions="Auto,*"
                          Padding="{Binding LeftPadding}">
                        <Grid.GestureRecognizers>
                            <!-- PointerEntered es hover puro: no interfiere con la selección por tap del CollectionView.
                                 Se usa para saber qué item tiene el puntero encima durante un drag. -->
                            <PointerGestureRecognizer PointerEnteredCommand="{Binding PointerEnteredCommand}"/>
                        </Grid.GestureRecognizers>

                        <!-- Expand / collapse icon (tap = toggle, also selects row) -->
                        <Label Grid.Column="0"
                               Text="{Binding ExpandIcon}"
                               TextColor="{StaticResource TextDim}"
                               FontSize="10"
                               WidthRequest="16"
                               HorizontalTextAlignment="Center"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleExpandCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>

                        <!-- Name label: single tap → selection (via CollectionView),
                                         double tap → inline rename -->
                        <Label Grid.Column="1"
                               Text="{Binding DisplayName}"
                               TextColor="{Binding NameColor}"
                               FontSize="12"
                               VerticalOptions="Center"
                               Margin="2,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer NumberOfTapsRequired="2"
                                                      Command="{Binding RenameCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="Empty scene"
                       Style="{StaticResource PlaceholderLabel}"
                       Margin="0,24"/>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- ── Status footer ─────────────────────────────────────── -->
        <Border Grid.Row="2"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0"
                Padding="8,0">
            <Label Text="{Binding StatusText}"
                   Style="{StaticResource DimLabel}"
                   VerticalOptions="Center"/>
        </Border>
        <!-- Footer top separator -->
        <BoxView Grid.Row="2" VerticalOptions="Start"
                 HeightRequest="1" Color="{StaticResource BorderColor}"/>

    </Grid>

        <!-- Resaltado del panel activo (overlay, sin afectar al layout) -->
        <Border InputTransparent="True" BackgroundColor="Transparent" StrokeThickness="1"
                Stroke="{Binding IsFocused, Converter={StaticResource BoolToColor}, ConverterParameter='#4A9EFF|#00000000'}"/>
    </Grid>
</ContentView>
