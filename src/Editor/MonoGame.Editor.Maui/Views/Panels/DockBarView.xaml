<?xml version="1.0" encoding="utf-8"?>
<ContentView x:Class="MonoGame.Editor.Maui.Views.Panels.DockBarView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:panels="clr-namespace:MonoGame.Editor.Maui.Views.Panels"
             xmlns:vm="clr-namespace:MonoGame.Editor.Maui.ViewModels.Panels"
             x:DataType="vm:DockBarViewModel"
             BackgroundColor="{StaticResource BgPanel}">

    <Grid RowDefinitions="26,*" RowSpacing="0">

        <!-- ── Dock tabs ─────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource BgChrome}"
                StrokeThickness="0">
            <ScrollView Orientation="Horizontal">
                <HorizontalStackLayout Spacing="0" x:Name="TabBar">

                    <Button Text="Scenes"
                            CommandParameter="Scenes"
                            Command="{Binding SelectTabCommand}"
                            Style="{StaticResource TabButton}"
                            TextColor="#9A9AA2">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding ActiveTab}" Value="Scenes">
                                <Setter Property="TextColor" Value="#E6E6E8"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button Text="Assets"
                            CommandParameter="Assets"
                            Command="{Binding SelectTabCommand}"
                            Style="{StaticResource TabButton}"
                            TextColor="#9A9AA2">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding ActiveTab}" Value="Assets">
                                <Setter Property="TextColor" Value="#E6E6E8"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button Text="Console"
                            CommandParameter="Console"
                            Command="{Binding SelectTabCommand}"
                            Style="{StaticResource TabButton}"
                            TextColor="#9A9AA2">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding ActiveTab}" Value="Console">
                                <Setter Property="TextColor" Value="#E6E6E8"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button Text="Localization"
                            CommandParameter="Localization"
                            Command="{Binding SelectTabCommand}"
                            Style="{StaticResource TabButton}"
                            TextColor="#9A9AA2">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding ActiveTab}" Value="Localization">
                                <Setter Property="TextColor" Value="#E6E6E8"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button Text="Input Maps"
                            CommandParameter="InputMaps"
                            Command="{Binding SelectTabCommand}"
                            Style="{StaticResource TabButton}"
                            TextColor="#9A9AA2">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding ActiveTab}" Value="InputMaps">
                                <Setter Property="TextColor" Value="#E6E6E8"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button Text="Tilemap"
                            CommandParameter="Tilemap"
                            Command="{Binding SelectTabCommand}"
                            Style="{StaticResource TabButton}"
                            TextColor="#9A9AA2">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding ActiveTab}" Value="Tilemap">
                                <Setter Property="TextColor" Value="#E6E6E8"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button Text="History"
                            CommandParameter="History"
                            Command="{Binding SelectTabCommand}"
                            Style="{StaticResource TabButton}"
                            TextColor="#9A9AA2">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding ActiveTab}" Value="History">
                                <Setter Property="TextColor" Value="#E6E6E8"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button Text="Scripts"
                            CommandParameter="Scripts"
                            Command="{Binding SelectTabCommand}"
                            Style="{StaticResource TabButton}"
                            TextColor="#9A9AA2">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding ActiveTab}" Value="Scripts">
                                <Setter Property="TextColor" Value="#E6E6E8"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                </HorizontalStackLayout>
            </ScrollView>
        </Border>
        <!-- Tabs top separator -->
        <BoxView Grid.Row="0" VerticalOptions="Start"
                 HeightRequest="1" Color="{StaticResource BorderColor}"/>

        <!-- ── Tab content area ─────────────────────────────────── -->
        <Grid Grid.Row="1">

            <!-- Scenes tab (default) -->
            <panels:SceneManagerView x:Name="ScenesContent"/>

            <!-- Assets tab -->
            <panels:AssetBrowserView x:Name="AssetsContent" IsVisible="False"/>

            <!-- Console tab -->
            <panels:ConsolePanelView x:Name="ConsoleContent" IsVisible="False"/>

            <!-- Phase 7 tabs -->
            <panels:LocalizationBrowserView x:Name="LocalizationContent" IsVisible="False"/>
            <panels:InputMapEditorView      x:Name="InputMapsContent"    IsVisible="False"/>
            <panels:TilemapPaletteView      x:Name="TilemapContent"      IsVisible="False"/>
            <panels:UndoHistoryView         x:Name="HistoryContent"      IsVisible="False"/>
            <panels:ScriptBrowserView       x:Name="ScriptsContent"      IsVisible="False"/>

        </Grid>
    </Grid>
</ContentView>
