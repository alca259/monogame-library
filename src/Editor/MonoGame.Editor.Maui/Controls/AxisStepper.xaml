<?xml version="1.0" encoding="utf-8"?>
<ContentView x:Class="MonoGame.Editor.Maui.Controls.AxisStepper"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Name="self">

    <Border Style="{StaticResource InputShell}">
        <Grid ColumnDefinitions="20,*,18" ColumnSpacing="0">

            <!-- Colored axis tag (hidden when ShowAxisTag=False) -->
            <Border Grid.Column="0"
                    x:Name="AxisTagBorder"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 3,0,0,3">
                <Label x:Name="AxisLabel"
                       TextColor="White"
                       FontSize="11"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"/>
            </Border>

            <!-- Numeric entry -->
            <Entry Grid.Column="1"
                   x:Name="ValueEntry"
                   Style="{StaticResource InputEntry}"
                   Keyboard="Numeric"
                   TextChanged="OnEntryTextChanged"
                   Completed="OnEntryCompleted"
                   Unfocused="OnEntryUnfocused"/>

            <!-- Step buttons -->
            <VerticalStackLayout Grid.Column="2" Spacing="0">
                <Button Text="▲"
                        Padding="0"
                        FontSize="7"
                        HeightRequest="14"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource TextSecondary}"
                        Clicked="OnIncrement"/>
                <Button Text="▼"
                        Padding="0"
                        FontSize="7"
                        HeightRequest="14"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource TextSecondary}"
                        Clicked="OnDecrement"/>
            </VerticalStackLayout>

        </Grid>
    </Border>
</ContentView>
