<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ════════════════════════════════════════════════════════
         TEXT  (canonical)
         ════════════════════════════════════════════════════════ -->

    <Style x:Key="LabelSecondary" TargetType="Label">
        <Setter Property="TextColor"            Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontSize"             Value="12"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ValueText" TargetType="Label">
        <Setter Property="TextColor"            Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontSize"             Value="13"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="SectionTitle" TargetType="Label">
        <Setter Property="TextColor"            Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontSize"             Value="13"/>
        <Setter Property="FontAttributes"       Value="Bold"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <!-- Monospace — IDs, console output -->
    <Style x:Key="MonoLabel" TargetType="Label">
        <Setter Property="TextColor"  Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="FontFamily" Value="Consolas"/>
    </Style>

    <!-- Empty-state placeholder -->
    <Style x:Key="PlaceholderLabel" TargetType="Label">
        <Setter Property="TextColor"           Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="HorizontalOptions"   Value="Center"/>
        <Setter Property="VerticalOptions"     Value="Center"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         TEXT  (legacy aliases — keep old style keys working)
         ════════════════════════════════════════════════════════ -->

    <Style x:Key="PrimaryLabel"    TargetType="Label" BasedOn="{StaticResource ValueText}"/>
    <Style x:Key="SecondaryLabel"  TargetType="Label" BasedOn="{StaticResource LabelSecondary}"/>

    <Style x:Key="DimLabel" TargetType="Label">
        <Setter Property="TextColor"            Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize"             Value="11"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PanelTitleLabel" TargetType="Label">
        <Setter Property="TextColor"            Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontSize"             Value="11"/>
        <Setter Property="FontAttributes"       Value="Bold"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         INPUTS
         ════════════════════════════════════════════════════════ -->

    <!-- InputShell: Border wrapper around Entry fields -->
    <Style x:Key="InputShell" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource InputBackground}"/>
        <Setter Property="Stroke"          Value="{StaticResource Border}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="StrokeShape"     Value="RoundRectangle 4"/>
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="HeightRequest"   Value="28"/>
    </Style>

    <!-- InputEntry: plain Entry (transparent when inside InputShell; own bg otherwise) -->
    <Style x:Key="InputEntry" TargetType="Entry">
        <Setter Property="BackgroundColor"  Value="Transparent"/>
        <Setter Property="TextColor"        Value="{StaticResource TextPrimary}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize"         Value="13"/>
        <Setter Property="Margin"           Value="8,0,0,0"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         BUTTONS  (canonical)
         ════════════════════════════════════════════════════════ -->

    <!-- FlatButton: transparent action button (toolbar icons, menu items) -->
    <Style x:Key="FlatButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor"       Value="{StaticResource TextSecondary}"/>
        <Setter Property="BorderWidth"     Value="0"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="8,4"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundHover}"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor"       Value="{StaticResource TextMuted}"/>
                            <Setter Property="BackgroundColor" Value="Transparent"/>
                            <Setter Property="Opacity"         Value="0.45"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- AddButton: full-width action like "+ Add Behaviour" -->
    <Style x:Key="AddButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource InputBackground}"/>
        <Setter Property="TextColor"       Value="{StaticResource TextSecondary}"/>
        <Setter Property="BorderColor"     Value="{StaticResource Border}"/>
        <Setter Property="BorderWidth"     Value="1"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="HeightRequest"   Value="34"/>
        <Setter Property="FontSize"        Value="13"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         BUTTONS  (legacy — keep old style keys working)
         ════════════════════════════════════════════════════════ -->

    <Style x:Key="MenuButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
        <Setter Property="TextColor"     Value="{StaticResource TextPrimary}"/>
        <Setter Property="HeightRequest" Value="28"/>
    </Style>

    <Style x:Key="ToolButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
        <Setter Property="TextColor"     Value="{StaticResource TextPrimary}"/>
        <Setter Property="HeightRequest" Value="30"/>
        <Setter Property="WidthRequest"  Value="30"/>
        <Setter Property="FontSize"      Value="15"/>
        <Setter Property="Padding"       Value="0"/>
        <Setter Property="CornerRadius"  Value="5"/>
    </Style>

    <Style x:Key="ActiveToolButton" TargetType="Button" BasedOn="{StaticResource ToolButton}">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentBlue}"/>
        <Setter Property="TextColor"       Value="White"/>
    </Style>

    <Style x:Key="SmallIconButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
        <Setter Property="TextColor"     Value="{StaticResource TextPrimary}"/>
        <Setter Property="HeightRequest" Value="26"/>
        <Setter Property="WidthRequest"  Value="26"/>
        <Setter Property="FontSize"      Value="13"/>
        <Setter Property="Padding"       Value="0"/>
        <Setter Property="CornerRadius"  Value="4"/>
    </Style>

    <!-- Mode toggle pills -->
    <Style x:Key="PillButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PanelBackgroundAlt}"/>
        <Setter Property="TextColor"       Value="{StaticResource TextSecondary}"/>
        <Setter Property="BorderColor"     Value="{StaticResource Border}"/>
        <Setter Property="BorderWidth"     Value="1"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="10,4"/>
        <Setter Property="HeightRequest"   Value="26"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor"       Value="{StaticResource TextMuted}"/>
                            <Setter Property="BackgroundColor" Value="{StaticResource PanelBackgroundAlt}"/>
                            <Setter Property="Opacity"         Value="0.45"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="ActivePillButton" TargetType="Button" BasedOn="{StaticResource PillButton}">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentBlue}"/>
        <Setter Property="TextColor"       Value="White"/>
        <Setter Property="BorderColor"     Value="{StaticResource AccentBlue}"/>
    </Style>

    <!-- Transport buttons -->
    <Style x:Key="PlayButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PlayGreen}"/>
        <Setter Property="TextColor"       Value="White"/>
        <Setter Property="BorderWidth"     Value="0"/>
        <Setter Property="CornerRadius"    Value="5"/>
        <Setter Property="Padding"         Value="8,4"/>
        <Setter Property="HeightRequest"   Value="28"/>
        <Setter Property="WidthRequest"    Value="36"/>
        <Setter Property="FontSize"        Value="16"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource PanelBackgroundAlt}"/>
                            <Setter Property="TextColor"       Value="{StaticResource TextMuted}"/>
                            <Setter Property="Opacity"         Value="0.55"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="StopButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PanelBackgroundAlt}"/>
        <Setter Property="TextColor"       Value="{StaticResource TextMuted}"/>
        <Setter Property="BorderWidth"     Value="0"/>
        <Setter Property="CornerRadius"    Value="5"/>
        <Setter Property="Padding"         Value="8,4"/>
        <Setter Property="HeightRequest"   Value="28"/>
        <Setter Property="WidthRequest"    Value="36"/>
        <Setter Property="FontSize"        Value="14"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource PanelBackgroundAlt}"/>
                            <Setter Property="TextColor"       Value="{StaticResource TextMuted}"/>
                            <Setter Property="Opacity"         Value="0.45"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="ActiveStopButton" TargetType="Button" BasedOn="{StaticResource StopButton}">
        <Setter Property="BackgroundColor" Value="{StaticResource StopRed}"/>
        <Setter Property="TextColor"       Value="White"/>
    </Style>

    <!-- Tabs -->
    <Style x:Key="TabButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor"       Value="{StaticResource TextSecondary}"/>
        <Setter Property="BorderWidth"     Value="0"/>
        <Setter Property="CornerRadius"    Value="0"/>
        <Setter Property="Padding"         Value="12,6"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="HeightRequest"   Value="26"/>
    </Style>

    <Style x:Key="InspectorTabButton" TargetType="Button" BasedOn="{StaticResource TabButton}"/>

    <Style x:Key="TabLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontSize"  Value="12"/>
        <Setter Property="Padding"   Value="10,8"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         BADGES, TAGS, PANELS
         ════════════════════════════════════════════════════════ -->

    <Style x:Key="Badge" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource InputBackground}"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="StrokeShape"     Value="RoundRectangle 4"/>
        <Setter Property="Padding"         Value="6,2"/>
    </Style>

    <!-- Colored axis tag (X red / Y green / Z blue) — set BackgroundColor per axis -->
    <Style x:Key="AxisTag" TargetType="Border">
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="WidthRequest"    Value="20"/>
        <Setter Property="HeightRequest"   Value="20"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions"   Value="Center"/>
    </Style>

    <Style x:Key="Panel" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PanelBackground}"/>
        <Setter Property="StrokeThickness" Value="0"/>
    </Style>

    <Style x:Key="PanelToolbarContainer" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PanelBackgroundAlt}"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="Padding"         Value="4,2"/>
        <Setter Property="HeightRequest"   Value="28"/>
    </Style>

    <Style x:Key="Divider" TargetType="BoxView">
        <Setter Property="Color"         Value="{StaticResource Border}"/>
        <Setter Property="HeightRequest" Value="1"/>
    </Style>

</ResourceDictionary>
