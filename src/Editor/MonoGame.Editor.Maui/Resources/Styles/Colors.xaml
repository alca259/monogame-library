<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ════════════════════════════════════════════════════════
         CANONICAL THEME TOKENS  (use these in new code)
         ════════════════════════════════════════════════════════ -->

    <!-- Backgrounds -->
    <Color x:Key="ShellBackground">#1A1A1B</Color>
    <Color x:Key="PanelBackground">#1E1E20</Color>
    <Color x:Key="PanelBackgroundAlt">#252528</Color>
    <Color x:Key="ViewportBackground">#141416</Color>
    <Color x:Key="InputBackground">#2A2A2E</Color>
    <Color x:Key="InputBackgroundHover">#323237</Color>
    <Color x:Key="RowSelected">#2D4A6B</Color>

    <!-- Borders -->
    <Color x:Key="Border">#34343A</Color>
    <Color x:Key="BorderFocus">#4A9EFF</Color>

    <!-- Accents -->
    <Color x:Key="AccentBlue">#4A9EFF</Color>
    <Color x:Key="AccentBlueDim">#2F6FB0</Color>

    <!-- Axes (gizmo + AxisStepper tags) -->
    <Color x:Key="AxisRed">#E5484D</Color>
    <Color x:Key="AxisGreen">#46C66A</Color>
    <Color x:Key="AxisBlue">#4A9EFF</Color>

    <!-- Transport -->
    <Color x:Key="PlayGreen">#46C66A</Color>
    <Color x:Key="StopRed">#E5484D</Color>

    <!-- Build status -->
    <Color x:Key="BuildErrorBg">#C73E3E</Color>
    <Color x:Key="BuildErrorFg">#FFFFFF</Color>
    <Color x:Key="BuildOkFg">#9A9AA2</Color>

    <!-- FPS indicator -->
    <Color x:Key="FpsGreen">#46C66A</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#E6E6E8</Color>
    <Color x:Key="TextSecondary">#9A9AA2</Color>
    <Color x:Key="TextMuted">#6A6A72</Color>

    <!-- Special -->
    <Color x:Key="MaterialIcon">#E5484D</Color>

    <!-- ════════════════════════════════════════════════════════
         LEGACY ALIASES  (kept for backward compatibility)
         These map old key names to the new canonical values.
         ════════════════════════════════════════════════════════ -->

    <Color x:Key="BgWindow">#1A1A1B</Color>
    <Color x:Key="BgChrome">#252528</Color>
    <Color x:Key="BgPanel">#1E1E20</Color>
    <Color x:Key="BgRaised">#252528</Color>
    <Color x:Key="BgInput">#2A2A2E</Color>
    <Color x:Key="BgViewport">#141416</Color>
    <Color x:Key="TextDim">#6A6A72</Color>
    <Color x:Key="TextFaint">#6A6A72</Color>
    <Color x:Key="AccentGreen">#46C66A</Color>
    <Color x:Key="AccentRed">#E5484D</Color>
    <Color x:Key="AccentAmber">#E3A33B</Color>
    <Color x:Key="BorderColor">#34343A</Color>
    <Color x:Key="AxisX">#E5484D</Color>
    <Color x:Key="AxisY">#46C66A</Color>
    <Color x:Key="AxisZ">#4A9EFF</Color>

</ResourceDictionary>
