<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <RootNamespace>Alca.MonoGame.Kernel</RootNamespace>
    <AssemblyName>Alca.MonoGame.Kernel</AssemblyName>
    <PackageId>Alca.MonoGame.Kernel</PackageId>
    <Authors>Alca</Authors>
    <Company>Alca259</Company>
    <Product>Alca MonoGame Framework</Product>

    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageOutputPath>F:\Dev\NugetLocal\</PackageOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.*" />
    <PackageReference Include="Microsoft.Extensions.Localization" Version="10.0.*" />
    <PackageReference Include="MonoGame.Framework.DesktopGL" Version="3.8.*">
      <PrivateAssets>All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="MonoGame.Extended" Version="6.0.*" />
    <PackageReference Include="Aether.Physics2D.MG" Version="2.2.*" />
    <PackageReference Include="LiteNetLib" Version="1.3.*" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>Alca.MonoGame.Kernel.UnitTests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>
</Project>